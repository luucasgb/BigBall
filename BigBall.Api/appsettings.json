{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "Properties": {
      "Application": "BigBall.Api"
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Supabase": ""
  },
  "Supabase": {
    "ProjectUrl": "",
    "PublishableKey": "",
    "JwtAudience": "authenticated"
  },
  "Fixtures": {
    "ImportWorldCup2026": false
  },
  "SportsData": {
    "Provider": "FlashScore"
  },
  "FlashScore": {
    "BaseUrl": "https://flashscore4.p.rapidapi.com",
    "ApiKey": "",
    "RapidApiHost": "flashscore4.p.rapidapi.com"
  },
  "SportsApiPro": {
    "BaseUrl": "https://v2.football.sportsapipro.com",
    "ApiKey": ""
  },
  "MatchProviderSync": {
    "Enabled": false,
    "DailyRequestBudget": null,
    "TickSeconds": 90,
    "WarmWindowBeforeKickoffMinutes": 180,
    "PollHorizonHoursAfterKickoff": 10,
    "SecondsPreMatchStale": 7200,
    "SecondsFirstHalf": 90,
    "SecondsSecondHalf": 75,
    "SecondsHalftimeBreak": 60,
    "SecondsExtraOrPenalties": 45,
    "SecondsTerminalReconciliation": 480
  },
  "AllowedHosts": "*"
}
