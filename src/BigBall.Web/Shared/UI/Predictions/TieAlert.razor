<!-- Tie alert shown when current user is in a tie with other members -->
@if (Show)
{
    <div class="tie-alert">
        <div class="tie-alert-icon">
            <Icon Path="@IconPaths.Alert" Size="18" />
        </div>
        <div class="tie-alert-content">
            <div class="tie-alert-title">Empate no ranking</div>
            <div class="tie-alert-message">
                Você está empatado com outro membro. Desempate pelo número de
                placares exatos (20 pts), depois 16 pts, e assim por diante (PRD 4.8).
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
}

<style>
    .tie-alert {
        padding: 20px 24px;
        background: color-mix(in oklab, var(--warning) 8%, var(--bg-elev));
        border: 1px solid color-mix(in oklab, var(--warning) 35%, transparent);
        border-radius: 8px;
        display: flex;
        gap: 12px;
    }

    .tie-alert-icon {
        color: var(--warning);
        flex-shrink: 0;
        margin-top: 2px;
    }

    .tie-alert-content {
        flex: 1;
    }

    .tie-alert-title {
        font-weight: 600;
        color: var(--fg);
        margin-bottom: 4px;
    }

    .tie-alert-message {
        font-size: 13px;
        color: var(--fg-2);
        line-height: 1.5;
    }
</style>
