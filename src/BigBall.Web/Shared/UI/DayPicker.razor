<div class="day-picker">
    @foreach (var day in Items)
    {
        var isActive = day.Label == Selected;
        <div class="day-picker-tile @(isActive ? "active" : "")"
             @onclick="() => SelectedChanged.InvokeAsync(day.Label)">
            <div class="day-picker-name">@day.DayName</div>
            <div class="day-picker-num">@day.DayNum</div>
            <div class="day-picker-count">@day.MatchCount jogos</div>
        </div>
    }
</div>

@code {
    public record DayPickerItem(string DayName, string DayNum, string Label, int MatchCount);

    [Parameter] public IReadOnlyList<DayPickerItem> Items { get; set; } = [];
    [Parameter] public string Selected { get; set; } = "";
    [Parameter] public EventCallback<string> SelectedChanged { get; set; }
}

<style>
    .day-picker {
        padding: 0 40px 20px;
        display: flex;
        gap: 8px;
    }

    .day-picker-tile {
        flex: 1;
        padding: 14px 16px;
        border-radius: 12px;
        background: var(--bg-elev);
        border: 1px solid var(--line);
        color: var(--fg);
        cursor: pointer;
        transition: background 0.1s, border-color 0.1s, color 0.1s;
    }

    .day-picker-tile.active {
        background: var(--brand-strong);
        border-color: var(--brand-strong);
        color: var(--brand-ink);
    }

    .day-picker-name {
        font-size: 11px;
        opacity: 0.7;
        letter-spacing: 0.06em;
        font-weight: 500;
    }

    .day-picker-num {
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin-top: 2px;
    }

    .day-picker-count {
        font-size: 11px;
        opacity: 0.7;
        margin-top: 4px;
    }
</style>
