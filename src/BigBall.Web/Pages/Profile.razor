@page "/profile"

<div class="bb-desk theme-dark">
    <Sidebar Active="profile" />
    <main class="bb-main">
        <DesktopTopbar Placeholder="Buscar membros, partidas, palpites…" />

        <div class="bb-page-h">
            <div style="flex:1;">
                <div class="bb-page-eyebrow">Conta</div>
                <div class="bb-page-title">Perfil</div>
            </div>
            <button class="bb-topbar-btn"><Icon Path="@IconPaths.Share" Size="16" /> Compartilhar</button>
            <button class="bb-topbar-btn primary"><Icon Path="@IconPaths.Pen" Size="16" /> Editar</button>
        </div>

        <div class="bb-content">

            <div style="padding:0 40px 24px;">
                <div class="bb-dcard" style="padding:0;overflow:hidden;background:linear-gradient(120deg, color-mix(in oklab, var(--brand-strong) 14%, var(--bg-elev)) 0%, var(--bg-elev) 55%);border-color:color-mix(in oklab, var(--brand-strong) 22%, var(--line));">
                    <div style="padding:28px 32px;display:flex;align-items:center;gap:24px;">
                        <div style="position:relative;">
                            <Avatar Name="@ProfileName" Size="104" />
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div style="font-family:var(--font-display);font-size:36px;font-weight:600;letter-spacing:-0.025em;line-height:1.1;">@ProfileName</div>
                                <span style="font-size:10px;padding:3px 8px;border-radius:6px;background:var(--chip-bg);color:var(--fg-2);letter-spacing:0.04em;font-weight:600;text-transform:uppercase;">@ProfileHandle</span>
                            </div>
                            <div style="display:flex;align-items:center;gap:16px;margin-top:8px;flex-wrap:wrap;">
                                <div style="font-size:13px;color:var(--fg-2);">@ProfileEmail</div>
                                <div style="font-size:13px;color:var(--fg-3);">·</div>
                                <div style="font-size:13px;color:var(--fg-2);">Membro desde mar/2026</div>
                                <div style="font-size:13px;color:var(--fg-3);">·</div>
                                <div style="font-size:13px;color:var(--fg-2);display:flex;align-items:center;gap:6px;">
                                    <Icon Path="@IconPaths.Globe" Size="14" /> America/São_Paulo (BRT)
                                </div>
                            </div>
                            <div style="display:flex;gap:6px;margin-top:12px;">
                                <span style="font-size:11px;padding:4px 9px;border-radius:6px;background:color-mix(in oklab, var(--brand-strong) 18%, transparent);color:var(--brand-strong);font-weight:600;letter-spacing:0.04em;text-transform:uppercase;">Admin de bolão · 1</span>
                                <span style="font-size:11px;padding:4px 9px;border-radius:6px;background:var(--chip-bg);color:var(--fg-2);font-weight:600;letter-spacing:0.04em;text-transform:uppercase;">Membro · 3 bolões</span>
                            </div>
                        </div>
                        <div style="display:grid;grid-template-columns:repeat(4, 1fr);gap:28px;padding-left:24px;border-left:1px solid var(--line);">
                            @foreach (var kpi in Kpis)
                            {
                                <div style="min-width:110px;">
                                    <div style="font-size:10px;color:var(--fg-3);letter-spacing:0.1em;text-transform:uppercase;font-weight:600;">@kpi.Label</div>
                                    <div style="font-family:var(--font-display);font-weight:700;font-size:38px;letter-spacing:-0.03em;line-height:1.1;margin-top:6px;font-variant-numeric:tabular-nums;color:@(kpi.Gold ? "var(--brand-strong)" : "var(--fg)");">@kpi.Value</div>
                                    <div style="font-size:11px;color:var(--fg-3);margin-top:2px;">@kpi.Sub</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div style="padding:0 40px 40px;display:grid;grid-template-columns:1.05fr 1.4fr 1fr;gap:20px;">

                <div style="display:flex;flex-direction:column;gap:20px;">
                    <div class="bb-dcard">
                        <div class="bb-dcard-h">
                            <div class="bb-dcard-title">Pontos por faixa</div>
                            <span class="bb-dcard-link" style="font-size:11px;color:var(--fg-3);">todos os bolões</span>
                        </div>
                        @foreach (var row in Faixas)
                        {
                            <div style="display:grid;grid-template-columns:36px 1fr 28px;align-items:center;gap:10px;padding:6px 0;">
                                <div style="font-family:var(--font-display);font-weight:700;color:@(row.P == 20 ? "var(--brand-strong)" : "var(--fg)");font-variant-numeric:tabular-nums;font-size:15px;">@row.P</div>
                                <div>
                                    <div style="font-size:11px;color:var(--fg-3);margin-bottom:4px;">@row.Label</div>
                                    <div style="height:6px;background:var(--chip-bg);border-radius:3px;overflow:hidden;">
                                        <div style="width:@(MaxFaixaN > 0 ? (row.N * 100 / MaxFaixaN) : 0)%;height:100%;background:@FaixaBarColor(row.P);"></div>
                                    </div>
                                </div>
                                <div style="font-size:12px;color:var(--fg-2);text-align:right;font-variant-numeric:tabular-nums;font-weight:500;">@(row.N)×</div>
                            </div>
                        }
                    </div>

                    <div class="bb-dcard">
                        <div class="bb-dcard-h"><div class="bb-dcard-title">Palpites enviados</div></div>
                        <div style="display:flex;align-items:baseline;gap:8px;">
                            <div style="font-family:var(--font-display);font-size:44px;font-weight:700;letter-spacing:-0.025em;font-variant-numeric:tabular-nums;">36</div>
                            <div style="font-size:14px;color:var(--fg-3);">/ 38 elegíveis</div>
                        </div>
                        <div style="height:8px;background:var(--chip-bg);border-radius:4px;overflow:hidden;margin-top:12px;">
                            <div style="width:94%;height:100%;background:var(--brand);"></div>
                        </div>
                        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--fg-3);margin-top:8px;">
                            <span>Taxa de acerto: <b style="color:var(--fg-2);">71%</b></span>
                            <span>2 perdidas</span>
                        </div>
                    </div>
                </div>

                <div style="display:flex;flex-direction:column;gap:20px;">
                    <div class="bb-dcard" style="padding:0;">
                        <div style="padding:18px 20px;display:flex;align-items:center;border-bottom:1px solid var(--line);">
                            <div class="bb-dcard-title">Atividade de palpites</div>
                            <span class="bb-dcard-link" style="margin-left:auto;">Ver tudo <Icon Path="@IconPaths.Chevron" Size="14" /></span>
                        </div>
                        <table class="bb-table">
                            <thead>
                                <tr>
                                    <th style="padding-left:20px;">Partida</th>
                                    <th>Bolão</th>
                                    <th style="text-align:right;">Resultado</th>
                                    <th style="text-align:right;">Palpite</th>
                                    <th style="text-align:right;padding-right:20px;">Pts</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in RecentActivity)
                                {
                                    <tr>
                                        <td style="padding-left:20px;">
                                            <div style="font-weight:500;">@r.Match</div>
                                            <div style="font-size:11px;color:var(--fg-3);margin-top:2px;">@r.When</div>
                                        </td>
                                        <td style="font-size:13px;color:var(--fg-2);">@r.Pool</td>
                                        <td class="num" style="color:var(--fg-2);font-family:var(--font-sans);font-weight:500;font-size:14px;">@r.Score</td>
                                        <td class="num" style="color:var(--fg-3);font-family:var(--font-sans);font-weight:500;font-size:14px;">@r.Pred</td>
                                        <td class="num" style="padding-right:20px;font-size:17px;color:@PtsColor(r.Pts);">@(r.Pts > 0 ? "+" + r.Pts : "0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="bb-dcard">
                        <div class="bb-dcard-h">
                            <div class="bb-dcard-title">Meus bolões</div>
                            <span class="bb-dcard-link">Ver todos <Icon Path="@IconPaths.Chevron" Size="14" /></span>
                        </div>
                        <div style="display:flex;flex-direction:column;gap:8px;">
                            @foreach (var p in MyPools)
                            {
                                <div style="padding:12px 14px;border-radius:12px;border:1px solid var(--line);display:flex;align-items:center;gap:14px;">
                                    <div style="width:38px;height:38px;border-radius:10px;background:@(p.Rank == 1 ? "color-mix(in oklab, var(--brand-strong) 22%, transparent)" : "var(--chip-bg)");color:@(p.Rank == 1 ? "var(--brand-strong)" : "var(--fg-2)");display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <Icon Path="@IconPaths.Trophy" Size="18" />
                                    </div>
                                    <div style="flex:1;min-width:0;">
                                        <div style="display:flex;align-items:center;gap:8px;font-size:14px;font-weight:500;">
                                            @p.Name
                                            @if (p.IsAdmin)
                                            {
                                                <span style="font-size:9px;padding:2px 6px;border-radius:4px;background:color-mix(in oklab, var(--brand-strong) 22%, transparent);color:var(--brand-strong);font-weight:700;letter-spacing:0.06em;">ADMIN</span>
                                            }
                                        </div>
                                        <div style="font-size:11px;color:var(--fg-3);margin-top:2px;">@p.Members membros</div>
                                    </div>
                                    <div style="text-align:right;">
                                        <div style="font-size:11px;color:var(--fg-3);">posição</div>
                                        <div style="font-family:var(--font-display);font-weight:700;font-size:20px;color:@(p.Rank == 1 ? "var(--brand-strong)" : "var(--fg)");font-variant-numeric:tabular-nums;line-height:1;">#@p.Rank</div>
                                    </div>
                                    <div style="text-align:right;min-width:60px;">
                                        <div style="font-size:11px;color:var(--fg-3);">pontos</div>
                                        <div style="font-family:var(--font-display);font-weight:700;font-size:20px;font-variant-numeric:tabular-nums;line-height:1;">@p.Pts</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div style="display:flex;flex-direction:column;gap:20px;">
                    <div class="bb-dcard" style="padding:0;">
                        <div style="padding:18px 20px;border-bottom:1px solid var(--line);"><div class="bb-dcard-title">Conta</div></div>
                        @foreach (var (row, idx) in AccountRows.Select((r, i) => (r, i)))
                        {
                            <div style="display:flex;align-items:center;gap:12px;padding:14px 20px;border-bottom:@(idx < AccountRows.Count - 1 ? "1px solid var(--line)" : "none");cursor:pointer;">
                                <div style="color:var(--fg-2);"><Icon Path="@row.Icon" Size="18" /></div>
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:13px;font-weight:500;">@row.Label</div>
                                    <div style="font-size:11px;color:var(--fg-3);margin-top:2px;">@row.Value</div>
                                </div>
                                <span style="color:var(--fg-3);"><Icon Path="@IconPaths.Chevron" Size="16" /></span>
                            </div>
                        }
                    </div>
                    <button class="bb-btn bb-btn-ghost" style="width:100%;height:44px;color:var(--danger);border-color:color-mix(in oklab, var(--danger) 35%, var(--line));">
                        Sair da conta
                    </button>
                </div>

            </div>
        </div>
    </main>
</div>

@code {
    private const string ProfileName   = "João Pereira";
    private const string ProfileHandle = "@joao.pereira";
    private const string ProfileEmail  = "joao.pereira@gmail.com";

    private record KpiItem(string Label, string Value, string Sub, bool Gold = false);
    private static readonly IReadOnlyList<KpiItem> Kpis =
    [
        new("Pontos totais",  "549",  "em 3 bolões",    Gold: true),
        new("Melhor posição", "#1",   "Trampo TechCo"),
        new("Placar exato",   "6×",   "20 pts cada"),
        new("Bônus pênaltis", "3×",   "+3 pts cada"),
    ];

    private record FaixaItem(int P, int N, string Label);
    private static readonly IReadOnlyList<FaixaItem> Faixas =
    [
        new(20, 6,  "Placar exato"),
        new(16, 11, "Vencedor + saldo"),
        new(15, 4,  "Vencedor + 1 placar"),
        new(10, 8,  "Apenas vencedor"),
        new(5,  5,  "Apenas 1 placar"),
        new(0,  2,  "Sem pontos"),
    ];
    private static int MaxFaixaN => Faixas.Max(f => f.N);

    private static string FaixaBarColor(int p) => p switch
    {
        20        => "var(--brand-strong)",
        >= 15     => "color-mix(in oklab, var(--brand-strong) 70%, var(--brand))",
        >= 10     => "var(--brand)",
        >= 5      => "color-mix(in oklab, var(--brand) 60%, var(--fg-3))",
        _         => "var(--fg-3)",
    };

    private record ActivityRow(string Match, string Pool, string Score, string Pred, int Pts, string When);
    private static readonly IReadOnlyList<ActivityRow> RecentActivity =
    [
        new("FRA × SUI",  "Família Silva",  "2×1", "2×1", 20, "Há 2h"),
        new("POR × CRO",  "Trampo TechCo", "3×0", "2×0", 15, "Ontem"),
        new("ENG × USA",  "Trampo TechCo", "1×1", "2×1", 5,  "Ontem"),
        new("BRA × SRB",  "Galera do FC",  "2×0", "1×0", 16, "Sex"),
        new("NED × ECU",  "Família Silva",  "1×1", "1×1", 20, "Sex"),
        new("KOR × URU",  "Trampo TechCo", "0×0", "1×2", 0,  "Qui"),
    ];
    private static string PtsColor(int pts) => pts >= 16 ? "var(--success)" : pts >= 10 ? "var(--brand-strong)" : pts > 0 ? "var(--fg-2)" : "var(--fg-3)";

    private record PoolItem(string Name, int Members, bool IsAdmin, int Rank, int Pts);
    private static readonly IReadOnlyList<PoolItem> MyPools =
    [
        new("Trampo TechCo",      28, true,  1, 267),
        new("Família Silva 2026", 12, false, 2, 184),
        new("Galera do FC",        8, false, 5, 98),
    ];

    private record AccountRow(string Icon, string Label, string Value);
    private static readonly IReadOnlyList<AccountRow> AccountRows =
    [
        new(IconPaths.User,  "Nome de exibição",    "João Pereira"),
        new(IconPaths.Bell,  "Notificações",         "Lock T-5min · resultados"),
        new(IconPaths.Globe, "Fuso horário",         "America/São_Paulo (BRT)"),
        new(IconPaths.Lock,  "Privacidade & dados",  "LGPD · exportar · excluir"),
    ];
}
