@page "/pools/{PoolId:guid}/predict/{MatchId:guid}"
@inject PredictViewModel VM
@implements IDisposable

<div class="bb-desk theme-dark">
    <Sidebar Active="predict" />
    <main class="bb-main">
        <DesktopTopbar />
        <div class="bb-content">

            @if (VM.Match is { } m)
            {
                <MatchHeader Phase="@(m.GroupLabel ?? m.Phase)"
                             HomeCode="@m.HomeCode"
                             AwayCode="@m.AwayCode"
                             KickoffUtc="@m.KickoffUtc"
                             IsLocked="@VM.IsLocked"
                             SecondsUntilLock="@VM.SecondsUntilLock" />
            }
            else
            {
                <div class="bb-page-h">
                    <div class="bb-page-title">Palpite</div>
                </div>
            }

            @if (VM.Match is { } match)
            {
                <div class="prediction-page-grid">
                    <MatchCard HomeCode="@match.HomeCode"
                               AwayCode="@match.AwayCode"
                               HomePrediction="@VM.HomePrediction"
                               AwayPrediction="@VM.AwayPrediction"
                               IsLocked="@VM.IsLocked"
                               IsBusy="@VM.IsBusy"
                               HomeReferenceScore="@match.ReferenceHome"
                               AwayReferenceScore="@match.ReferenceAway"
                               Preview="@VM.Preview"
                               HomePredictionChanged="v => VM.HomePrediction = v"
                               AwayPredictionChanged="v => VM.AwayPrediction = v" />

                    <PredictionLayout>
                        <ScoringRulesCard />
                        <ErrorAlert Message="@VM.ErrorMessage" />
                        <SavePredictionButton IsSaved="@VM.IsSaved"
                                              IsBusy="@VM.IsBusy"
                                              CanSave="@(VM.SaveCommand.CanExecute(null))"
                                              OnSave="() => VM.SaveCommand.ExecuteAsync(null)" />
                    </PredictionLayout>
                </div>
            }
            else if (VM.IsBusy)
            {
                <div style="padding:40px;color:var(--fg-3);">Carregando…</div>
            }

        </div>
    </main>
</div>

@code {
    [Parameter] public Guid PoolId { get; set; }
    [Parameter] public Guid MatchId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (VM.PoolId == PoolId && VM.MatchId == MatchId) return;
        VM.PropertyChanged += OnVmChanged;
        VM.PoolId = PoolId;
        VM.MatchId = MatchId;
        await VM.LoadCommand.ExecuteAsync(null);
    }

    private void OnVmChanged(object? s, System.ComponentModel.PropertyChangedEventArgs e) => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        VM.PropertyChanged -= OnVmChanged;
        VM.Dispose();
    }
}

<style>
    .prediction-page-grid {
        padding: 0 40px 40px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        max-width: 960px;
    }
</style>
