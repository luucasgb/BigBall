@page "/login"
@inject LoginViewModel VM
@inject NavigationManager Nav
@implements IDisposable

<div class="bb-auth-page theme-dark">
    <AuthCard Subtitle="Entre com seu e-mail para acompanhar seus bolões.">
        <AuthForm @bind-Email="VM.Email" @bind-Password="VM.Password" Disabled="@VM.IsBusy" />

        <ErrorAlert Message="@VM.ErrorMessage" />

        <AuthButton Label="Entrar"
                    BusyLabel="Entrando…"
                    IsBusy="@VM.IsBusy"
                    Disabled="@(!VM.LoginCommand.CanExecute(null))"
                    OnClick="ExecuteLogin" />

        <button class="bb-btn bb-btn-outline auth-google-button"
                type="button"
                disabled="@VM.IsBusy"
                @onclick="StartGoogleLogin">
            <svg class="auth-google-icon" viewBox="0 0 48 48" aria-hidden="true" focusable="false">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            Entrar com Google
        </button>

        <p class="auth-switch">
            <a class="auth-switch-link" href="/register">Criar conta</a>
        </p>
    </AuthCard>
</div>

@code {
    protected override void OnInitialized() => VM.PropertyChanged += OnVmChanged;

    private void OnVmChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e) => InvokeAsync(StateHasChanged);

    private async Task ExecuteLogin() => await VM.LoginCommand.ExecuteAsync(null);
    private async Task StartGoogleLogin()
    {
        var callback = $"{Nav.BaseUri.TrimEnd('/')}/auth/callback";
        await VM.StartGoogleLoginCommand.ExecuteAsync(callback);
        if (!string.IsNullOrWhiteSpace(VM.GoogleOAuthUrl))
        {
            Nav.NavigateTo(VM.GoogleOAuthUrl, forceLoad: true);
        }
    }

    public void Dispose() => VM.PropertyChanged -= OnVmChanged;
}

<style>
    .auth-google-button {
        width: 100%;
        margin-top: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .auth-google-icon {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
    }

    .auth-switch {
        text-align: center;
        margin: 0;
        font-size: 14px;
    }

    .auth-switch-link {
        color: var(--brand-strong);
        text-decoration: none;
        font-weight: 500;
    }

    .auth-switch-link:hover {
        text-decoration: underline;
    }
</style>
