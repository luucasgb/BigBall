@page "/profile"

<div class="bb-desk theme-dark">
    <Sidebar Active="profile" />
    <main class="bb-main">
        <DesktopTopbar Placeholder="Buscar membros, partidas, palpites…" />

        <PageHeader Title="Perfil" Eyebrow="Conta">
            <button class="bb-topbar-btn"><Icon Path="@IconPaths.Share" Size="16" /> Compartilhar</button>
            <button class="bb-topbar-btn primary"><Icon Path="@IconPaths.Pen" Size="16" /> Editar</button>
        </PageHeader>

        <div class="bb-content">
            <ProfileHero
                Name="@ProfileName"
                Handle="@ProfileHandle"
                Email="@ProfileEmail"
                MemberSince="Membro desde mar/2026"
                Timezone="America/São_Paulo (BRT)"
                AdminOfLabel="Admin de bolão · 1"
                MemberLabel="Membro · 3 bolões"
                KpiItems="@ProfileKpiItems" />

            <div class="profile-layout">
                <div class="profile-column-left">
                    <ScoringBandsCard
                        Title="Pontos por faixa"
                        Subtitle="todos os bolões"
                        Items="@ScoringBandItems" />

                    <SubmissionsCard
                        Title="Palpites enviados"
                        Count="36"
                        Total="38"
                        FooterLeft="Taxa de acerto: 71%"
                        FooterRight="2 perdidas" />
                </div>

                <div class="profile-column-center">
                    <ActivityTable
                        Title="Atividade de palpites"
                        ViewAllLabel="Ver tudo"
                        Items="@ActivityItems" />

                    <MyPoolsCard
                        Title="Meus bolões"
                        ViewAllLabel="Ver todos"
                        Items="@PoolItems" />
                </div>

                <div class="profile-column-right">
                    <AccountSettingsCard
                        Title="Conta"
                        Items="@AccountSettingsItems" />

                    <button class="bb-btn bb-btn-ghost logout-btn">
                        Sair da conta
                    </button>
                </div>
            </div>
        </div>
    </main>
</div>

@code {
    private const string ProfileName   = "João Pereira";
    private const string ProfileHandle = "@joao.pereira";
    private const string ProfileEmail  = "joao.pereira@gmail.com";

    // KPI items for the hero section
    private static readonly IReadOnlyList<ProfileKpis.KpiItem> ProfileKpiItems =
    [
        new("Pontos totais",  "549",  "em 3 bolões",    IsHighlight: true),
        new("Melhor posição", "#1",   "Trampo TechCo"),
        new("Placar exato",   "6×",   "20 pts cada"),
        new("Bônus pênaltis", "3×",   "+3 pts cada"),
    ];

    // Scoring band items
    private static readonly IReadOnlyList<ScoringBandsCard.BandItem> ScoringBandItems =
    [
        new(20, "Placar exato", 6),
        new(16, "Vencedor + saldo", 11),
        new(15, "Vencedor + 1 placar", 4),
        new(10, "Apenas vencedor", 8),
        new(5,  "Apenas 1 placar", 5),
        new(0,  "Sem pontos", 2),
    ];

    // Recent activity items
    private static readonly IReadOnlyList<ActivityTable.ActivityRow> ActivityItems =
    [
        new("FRA × SUI",  "Família Silva",  "2×1", "2×1", 20, "Há 2h"),
        new("POR × CRO",  "Trampo TechCo", "3×0", "2×0", 15, "Ontem"),
        new("ENG × USA",  "Trampo TechCo", "1×1", "2×1", 5,  "Ontem"),
        new("BRA × SRB",  "Galera do FC",  "2×0", "1×0", 16, "Sex"),
        new("NED × ECU",  "Família Silva",  "1×1", "1×1", 20, "Sex"),
        new("KOR × URU",  "Trampo TechCo", "0×0", "1×2", 0,  "Qui"),
