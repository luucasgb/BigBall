@page "/pools/{PoolId:guid}"
@layout DesktopAppLayout
@inject PoolDetailViewModel VM
@inject NavigationManager Nav
@implements IDisposable

@if (VM.Pool is { } pool)
{
    <PoolHeader Name="@pool.Name"
                Visibility="@pool.Visibility"
                OnBack="@HandleBack" />

    <PoolTabNav SelectedTab="@VM.SelectedTab"
                OnTabChanged="tab => VM.SelectedTab = tab" />

    <div class="bb-content">
        <PoolDetailLayout ShowSidebar="@(VM.SelectedTab == PoolTab.Ranking)">
            <MainContent>
                @if (VM.SelectedTab == PoolTab.Ranking)
                {
                    <RankingTable Rows="@VM.Ranking.ToList()"
                                  MyPosition="@pool.MyPosition"
                                  MyPoints="@pool.MyPoints"
                                  HasTieWithMe="@VM.HasTieWithMe" />
                }
                else if (VM.SelectedTab == PoolTab.Matches)
                {
                    <PoolMatchesTable Matches="@VM.Matches.ToList()" />
                }
                else if (VM.SelectedTab == PoolTab.Prize)
                {
                    <div class="bb-dcard prize-card">
                        <div class="prize-card-label">Premiação</div>
                        @if (!string.IsNullOrWhiteSpace(pool.PrizeDescription))
                        {
                            <div class="prize-card-value">@pool.PrizeDescription</div>
                        }
                        else
                        {
                            <span class="bb-empty">Premiação a definir.</span>
                        }
                    </div>
                }
                else
                {
                    <div class="bb-dcard empty-state">
                        <span class="bb-empty">Em breve.</span>
                    </div>
                }
            </MainContent>
            <SidebarContent>
                <div class="pool-sidebar">
                    <TieAlert Show="@VM.HasTieWithMe" />

                    <MyPositionCard Position="@pool.MyPosition"
                                    Points="@pool.MyPoints" />

                    <LeaderCard LeaderName="@pool.Leader.Name"
                                LeaderPoints="@pool.Leader.Points" />
                </div>
            </SidebarContent>
        </PoolDetailLayout>
    </div>
}
else if (!string.IsNullOrEmpty(VM.ErrorMessage))
{
    <div class="error-container">
        <div class="bb-error">@VM.ErrorMessage</div>
    </div>
}
else
{
    <div class="loading-container">Carregando…</div>
}

@code {
    [Parameter] public Guid PoolId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (VM.PoolId == PoolId) return;
        VM.PropertyChanged += OnVmChanged;
        ((System.Collections.Specialized.INotifyCollectionChanged)VM.Ranking).CollectionChanged += OnCollectionChanged;
        ((System.Collections.Specialized.INotifyCollectionChanged)VM.Matches).CollectionChanged += OnCollectionChanged;
        VM.PoolId = PoolId;
        await VM.LoadCommand.ExecuteAsync(null);
    }

    private void OnVmChanged(object? s, System.ComponentModel.PropertyChangedEventArgs e) => InvokeAsync(StateHasChanged);
    private void OnCollectionChanged(object? s, System.Collections.Specialized.NotifyCollectionChangedEventArgs e) => InvokeAsync(StateHasChanged);

    private void HandleBack() => Nav.NavigateTo("/");

    public void Dispose()
    {
        VM.PropertyChanged -= OnVmChanged;
        ((System.Collections.Specialized.INotifyCollectionChanged)VM.Ranking).CollectionChanged -= OnCollectionChanged;
        ((System.Collections.Specialized.INotifyCollectionChanged)VM.Matches).CollectionChanged -= OnCollectionChanged;
    }
}

<style>
    .empty-state {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 200px;
    }

    .prize-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        min-height: 200px;
        text-align: center;
    }

    .prize-card-label {
        font-size: 12px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--fg-3);
    }

    .prize-card-value {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 28px;
        line-height: 1.2;
        color: var(--brand-strong);
        max-width: 32ch;
    }

    .error-container {
        padding: 40px;
    }

    .loading-container {
        padding: 40px;
        color: var(--fg-3);
    }

    .pool-sidebar {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
</style>

