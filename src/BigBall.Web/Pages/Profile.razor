}

<style>
    .profile-layout {
        padding: 0 40px 40px;
        display: grid;
        grid-template-columns: 1.05fr 1.4fr 1fr;
        gap: 20px;
    }

    .profile-column-left,
    .profile-column-center,
    .profile-column-right {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .logout-btn {
        width: 100%;
        height: 44px;
        color: var(--danger);
        border-color: color-mix(in oklab, var(--danger) 35%, var(--line));
    }
</style>
