@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject BigBall.Web.Platform.ICreatePoolDialogService CreatePoolDialog
@inject BigBall.Web.Platform.IJoinPoolDialogService JoinPoolDialog
@implements IDisposable

<div class="bb-desk theme-dark">
    <div class="bb-sidebar-wrap @(_drawerOpen ? "open" : "")">
        <Sidebar Active="@_active" />
    </div>
    <main class="bb-main">
        <div class="bb-mobile-appbar bb-mobile-only">
            <button type="button" class="bb-iconbtn" @onclick="OpenDrawer" aria-label="Abrir menu">
                <Icon Path="@IconPaths.Menu" Size="20" />
            </button>
            <div class="bb-mobile-brand">BigBall</div>
        </div>
        @Body
    </main>
    <div class="bb-drawer-backdrop @(_drawerOpen ? "open" : "")" @onclick="CloseDrawer"></div>
    <BottomNav Active="@_active" />
    <CreatePoolModalHost />
    <JoinPoolModalHost />
    <ProfileEditModalHost />
</div>

@code {
    private string _active = "dashboard";
    private bool _drawerOpen;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        // A modal (z-index 1000) abre por trás do drawer (1100) no mobile; fechamos o
        // drawer ao abrir um diálogo a partir dos atalhos "Novo bolão"/"Entrar com código".
        CreatePoolDialog.StateChanged += OnDialogStateChanged;
        JoinPoolDialog.StateChanged += OnDialogStateChanged;
        _active = DeskSidebarActive.FromPath(Nav.ToBaseRelativePath(Nav.Uri));
    }

    private void OpenDrawer() => _drawerOpen = true;

    private void CloseDrawer() => _drawerOpen = false;

    private void OnDialogStateChanged()
    {
        if ((CreatePoolDialog.IsOpen || JoinPoolDialog.IsOpen) && _drawerOpen)
        {
            _drawerOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _active = DeskSidebarActive.FromPath(Nav.ToBaseRelativePath(e.Location));
        _drawerOpen = false; // fecha o drawer ao navegar (mobile)
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        CreatePoolDialog.StateChanged -= OnDialogStateChanged;
        JoinPoolDialog.StateChanged -= OnDialogStateChanged;
    }
}
