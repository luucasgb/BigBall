<!-- Tab navigation for pool detail page -->
<div class="pool-tab-nav">
    <div class="t @(SelectedTab == PoolTab.Ranking ? "active" : "")"
         @onclick='() => OnTabChanged.InvokeAsync(PoolTab.Ranking)'>Ranking</div>
    <div class="t @(SelectedTab == PoolTab.Matches ? "active" : "")"
         @onclick='() => OnTabChanged.InvokeAsync(PoolTab.Matches)'>Jogos</div>
    <div class="t @(SelectedTab == PoolTab.Members ? "active" : "")"
         @onclick='() => OnTabChanged.InvokeAsync(PoolTab.Members)'>Membros</div>
    <div class="t @(SelectedTab == PoolTab.Prize ? "active" : "")"
         @onclick='() => OnTabChanged.InvokeAsync(PoolTab.Prize)'>Premiação & regras</div>
</div>

@code {
    [Parameter] public PoolTab SelectedTab { get; set; }
    [Parameter] public EventCallback<PoolTab> OnTabChanged { get; set; }
}

<style>
    .pool-tab-nav {
        display: flex;
        border-bottom: 1px solid var(--line);
        padding: 0 40px;
        gap: 0;
    }

    .pool-tab-nav :deep .t {
        flex: 0 1 auto;
        padding: 12px 20px;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        color: var(--fg-2);
        transition: all 200ms ease;
    }

    .pool-tab-nav :deep .t:hover {
        color: var(--fg);
        background: color-mix(in oklab, var(--brand-strong) 5%, transparent);
    }

    .pool-tab-nav :deep .t.active {
        color: var(--brand-strong);
        border-bottom-color: var(--brand-strong);
    }
</style>
