@page "/"
@using BigBall.Web.Shared.UI
@inject HomeViewModel VM
@inject BigBall.Client.Core.Abstractions.ITokenStore TokenStore
@inject NavigationManager Nav
@implements IDisposable

<div class="bb-desk theme-dark">
    <Sidebar Active="dashboard" />
    <main class="bb-main">
        <DesktopTopbar />
        <div class="bb-content">

            <PageHeader Title="Início"
                        Eyebrow="BigBall · Copa do Mundo 2026"
                        Subtitle="@(VM.FeaturedNextMatch is { } fn ? $"{VM.Pools.Count} bolão(ões) ativo(s) · próximo palpite fecha em {TimeFormatting.FormatKickoff(fn.KickoffUtc)}" : null)" />

            <div class="home-featured-section">
                <div class="home-featured-main">
                    <div class="bb-dcard">
                        <FeaturedMatchCard Next="@VM.FeaturedNextMatch"
                                          Featured="@VM.FeaturedPool"
                                          IsBusy="@VM.IsBusy"
                                          OnPredictionClick="() => VM.OpenFeaturedPredictionCommand.Execute(null)" />
                    </div>
                </div>

                <div class="home-featured-sidebar">
                    @if (VM.Pools.Count > 0)
                    {
                        var best = VM.Pools.OrderBy(p => p.MyRank).First();
                        <div class="bb-dcard">
                            <BestPositionCard BestPool="@best" />
                        </div>
                    }
                    <div class="bb-dcard">
                        <SummaryCard PoolCount="@VM.Pools.Count"
                                    ErrorMessage="@VM.ErrorMessage" />
                    </div>
                </div>
            </div>

            <div class="home-content-section">
                <div class="home-content-main">
                    <div class="bb-dcard">
                        <PoolsTable Pools="@VM.Pools"
                                   IsBusy="@VM.IsBusy"
                                   OnPoolClick="@OpenPool" />
                    </div>
                </div>

                <div class="home-content-sidebar">
                    <div class="bb-dcard">
                        <ActivityFeed />
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        VM.PropertyChanged += OnVmChanged;
        ((System.Collections.Specialized.INotifyCollectionChanged)VM.Pools).CollectionChanged += OnPoolsChanged;

        var token = await TokenStore.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await VM.LoadCommand.ExecuteAsync(null);

        if (VM.ErrorMessage is not null && string.IsNullOrEmpty(await TokenStore.GetTokenAsync()))
            Nav.NavigateTo("/login", replace: true);
    }

    private void OnVmChanged(object? s, System.ComponentModel.PropertyChangedEventArgs e) => InvokeAsync(StateHasChanged);
    private void OnPoolsChanged(object? s, System.Collections.Specialized.NotifyCollectionChangedEventArgs e) => InvokeAsync(StateHasChanged);
    private void OpenPool(dynamic pool) => VM.OpenPoolCommand.Execute(pool);

    public void Dispose()
    {
        VM.PropertyChanged -= OnVmChanged;
        ((System.Collections.Specialized.INotifyCollectionChanged)VM.Pools).CollectionChanged -= OnPoolsChanged;
    }
}

<style>
    .home-featured-section {
        padding: 0 40px 24px;
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
    }

    .home-featured-main {
        /* Contains FeaturedMatchCard in .bb-dcard */
    }

    .home-featured-sidebar {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .home-content-section {
        padding: 0 40px 40px;
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
    }

    .home-content-main {
        /* Contains PoolsTable in .bb-dcard */
    }

    .home-content-sidebar {
        /* Contains ActivityFeed in .bb-dcard */
    }
</style>
