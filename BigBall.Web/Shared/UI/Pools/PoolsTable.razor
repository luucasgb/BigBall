<div class="pools-table-container">
    <div class="bb-dcard-h">
        <div class="bb-dcard-title">Meus bolões</div>
    </div>
    @if (GetPoolCount() == 0 && !IsBusy)
    {
        <div class="bb-empty">Você ainda não participa de nenhum bolão.</div>
    }
    else if (Pools is not null)
    {
        <table class="bb-table">
            <thead>
                <tr>
                    <th>Bolão</th>
                    <th>Próximo jogo</th>
                    <th>Líder</th>
                    <th class="pools-table-th-right">Pos.</th>
                    <th class="pools-table-th-right">Pts</th>
                    <th class="pools-table-th-right">Membros</th>
                </tr>
            </thead>
            <tbody>
                @foreach (dynamic pool in Pools)
                {
                    <tr class="pools-table-row"
                        @onclick="() => OnPoolClick.InvokeAsync(pool)">
                        <td>
                            <div class="pools-table-name">
                                <div class="pools-table-icon" data-rank="@pool.MyRank">
                                    <Icon Path="@IconPaths.Trophy" Size="16" />
                                </div>
                                <div class="pools-table-name-text">@pool.Name</div>
                            </div>
                        </td>
                        <td class="pools-table-next-match">
                            @if (pool.NextMatch is { } nm)
                            {
                                @($"{nm.HomeCode} × {nm.AwayCode} · {TimeFormatting.FormatKickoff(nm.KickoffUtc)}")
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td>
                            <div class="pools-table-leader">
                                <Avatar Name="@pool.Leader.Name" Size="22" />
                                <span class="pools-table-leader-name">@pool.Leader.Name</span>
                                <span class="pools-table-leader-points">@pool.Leader.Points</span>
                            </div>
                        </td>
                        <td class="num pools-table-rank" data-rank="@pool.MyRank">#@pool.MyRank</td>
                        <td class="num">@pool.MyPoints</td>
                        <td class="num pools-table-member-count">@pool.MemberCount</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public System.Collections.IEnumerable? Pools { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public EventCallback<dynamic> OnPoolClick { get; set; }

    private int GetPoolCount()
    {
        if (Pools is null) return 0;
        if (Pools is System.Collections.ICollection col) return col.Count;
        return Pools.Cast<object>().Count();
    }

    private static string PoolIconBg(int rank) =>
        rank == 1 ? "color-mix(in oklab, var(--brand-strong) 20%, transparent)" : "var(--chip-bg)";

    private static string PoolIconColor(int rank) =>
        rank == 1 ? "var(--brand-strong)" : "var(--fg-2)";
}

<style>
    .pools-table-container {
        /* Inherits .bb-dcard styles from parent */
    }

    /* Higher specificity than the global `.bb-table th` (which forces text-align: left). */
    .bb-table th.pools-table-th-right {
        text-align: right;
    }

    .pools-table-row {
        cursor: pointer;
    }

    .pools-table-name {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .pools-table-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--chip-bg);
        color: var(--fg-2);
    }

    .pools-table-icon[data-rank="1"] {
        background: color-mix(in oklab, var(--brand-strong) 20%, transparent);
        color: var(--brand-strong);
    }

    .pools-table-name-text {
        font-weight: 500;
    }

    .pools-table-next-match {
        color: var(--fg-2);
        font-size: 13px;
    }

    .pools-table-leader {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pools-table-leader-name {
        font-size: 13px;
    }

    .pools-table-leader-points {
        font-size: 12px;
        color: var(--fg-3);
        font-variant-numeric: tabular-nums;
    }

    .pools-table-rank {
        color: var(--fg);
    }

    .pools-table-rank[data-rank="1"] {
        color: var(--brand-strong);
    }

    .pools-table-member-count {
        color: var(--fg-2);
    }
</style>
