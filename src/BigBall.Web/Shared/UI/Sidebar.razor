@* Fixed left-nav sidebar shared across all desktop screens. *@
@inject NavigationManager Nav

<aside class="bb-sidebar">
    <div class="bb-logo">
        <div class="bb-logo-mark">
            <Icon Path="@IconPaths.Trophy" Size="20" />
        </div>
        <div class="bb-logo-text">BigBall</div>
    </div>

    <div class="bb-nav-section">Bolões</div>
    <div class="bb-nav-item @(Active == "dashboard" ? "active" : "")" @onclick='() => Nav.NavigateTo("/")'>
        <Icon Path="@IconPaths.Home" Size="18" />
        <span>Início</span>
    </div>
    <div class="bb-nav-item @(Active == "calendar" ? "active" : "")" @onclick='() => Nav.NavigateTo("/calendar")'>
        <Icon Path="@IconPaths.Calendar" Size="18" />
        <span>Calendário</span>
    </div>
    <div class="bb-nav-item" style="opacity:0.4;cursor:not-allowed;" title="Em breve">
        <Icon Path="@IconPaths.Globe" Size="18" />
        <span>Descobrir</span>
    </div>

    <div class="bb-nav-section">Conta</div>
    <div class="bb-nav-item @(Active == "profile" ? "active" : "")" @onclick='() => Nav.NavigateTo("/profile")'>
        <Icon Path="@IconPaths.User" Size="18" />
        <span>Perfil</span>
    </div>

    <div class="bb-sidebar-foot">
        <Avatar Name="João Pereira" Size="36" />
        <div style="min-width:0;">
            <div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">João Pereira</div>
            <div style="font-size:11px;color:var(--fg-3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">joao.pereira@gmail.com</div>
        </div>
    </div>
</aside>

@code {
    [Parameter] public string Active { get; set; } = string.Empty;
}
