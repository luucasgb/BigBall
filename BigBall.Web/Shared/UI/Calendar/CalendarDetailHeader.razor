@using BigBall.Web.Shared.State
@inject TeamBadgeCache TeamBadges

<div class="calendar-detail-header">
    <div class="calendar-detail-chips">
        <span class="bb-chip">@Phase</span>
        <div class="calendar-detail-chips-spacer"></div>
        <PredictionLockCountdownChip KickoffUtc="@KickoffUtc" />
    </div>
    <div class="calendar-detail-teams">
        <div class="calendar-detail-team">
            <Flag Code="@HomeCode" Size="64" ImageUrl="@TeamBadges.GetBadgeUrl(HomeCode)" />
            <div class="calendar-detail-team-name">@HomeName</div>
        </div>
        <div class="calendar-detail-vs">
            <div class="calendar-detail-date">@CenterDateLine</div>
            <div class="calendar-detail-vs-label">vs</div>
            @if (!string.IsNullOrEmpty(VenueLine))
            {
                <div class="calendar-detail-venue">@VenueLine</div>
            }
        </div>
        <div class="calendar-detail-team">
            <Flag Code="@AwayCode" Size="64" ImageUrl="@TeamBadges.GetBadgeUrl(AwayCode)" />
            <div class="calendar-detail-team-name">@AwayName</div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Phase { get; set; } = "";
    [Parameter] public DateTime KickoffUtc { get; set; }
    [Parameter] public string CenterDateLine { get; set; } = "";
    [Parameter] public string? VenueLine { get; set; }
    [Parameter] public string HomeCode { get; set; } = "";
    [Parameter] public string AwayCode { get; set; } = "";
    [Parameter] public string HomeName { get; set; } = "";
    [Parameter] public string AwayName { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        await TeamBadges.EnsureLoadedAsync();
    }
}

<style>
    .calendar-detail-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--line);
        flex-shrink: 0;
    }

    .calendar-detail-chips {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 14px;
    }

    .calendar-detail-chips-spacer {
        flex: 1;
        min-width: 0;
    }

    .calendar-detail-teams {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 24px;
    }

    .calendar-detail-team {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }

    .calendar-detail-team-name {
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 600;
        letter-spacing: -0.02em;
        text-align: center;
    }

    .calendar-detail-vs {
        text-align: center;
        color: var(--fg-3);
    }

    .calendar-detail-date {
        font-size: 11px;
        letter-spacing: 0.08em;
    }

    .calendar-detail-venue {
        font-size: 11px;
        color: var(--fg-2);
        margin-top: 8px;
        max-width: 200px;
        line-height: 1.35;
    }

    .calendar-detail-vs-label {
        font-family: var(--font-display);
        font-size: 36px;
        font-weight: 600;
        color: var(--fg-2);
        margin: 4px 0;
    }
</style>
