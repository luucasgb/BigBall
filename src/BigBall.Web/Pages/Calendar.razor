@page "/calendar"

<div class="bb-desk theme-dark">
    <Sidebar Active="calendar" />
    <main class="bb-main">
        <DesktopTopbar Placeholder="Buscar partida ou seleção…" />

        <div class="bb-page-h">
            <div style="flex:1;">
                <div class="bb-page-eyebrow">Junho 2026 · Fase de grupos · Rodada 2</div>
                <div class="bb-page-title">Calendário</div>
            </div>
            <div style="display:flex;gap:6px;">
                <button class="bb-topbar-btn" style="width:38px;padding:0;"><Icon Path="@IconPaths.ChevronL" Size="18" /></button>
                <button class="bb-topbar-btn" style="width:38px;padding:0;"><Icon Path="@IconPaths.Chevron" Size="18" /></button>
                <button class="bb-topbar-btn">Hoje</button>
                <button class="bb-topbar-btn"><Icon Path="@IconPaths.Filter" Size="16" /> Bolão</button>
            </div>
        </div>

        <DayPicker Items="@Days.Select(d => new DayPicker.DayPickerItem(d.DayName, d.DayNum, d.Label, d.MatchCount)).ToList()"
                   Selected="@SelectedDay"
                   SelectedChanged="d => SelectedDay = d" />

        <div class="calendar-layout">

            <MatchListPanel Title="Jogos · 14 jun" Subtitle="4 jogos · 1 ao vivo">
                @foreach (var (match, idx) in Matches.Select((m, i) => (m, i)))
                {
                    <MatchListItem Time="@match.Time"
                                   Phase="@match.Phase"
                                   HomeCode="@match.HomeCode"
                                   AwayCode="@match.AwayCode"
                                   HomeName="@match.HomeName"
                                   AwayName="@match.AwayName"
                                   Status="@match.Status"
                                   ClosesIn="@match.ClosesIn"
                                   Minute="@match.Minute"
                                   LiveHome="@match.LiveHome"
                                   LiveAway="@match.LiveAway"
                                   PredHome="@match.PredHome"
                                   PredAway="@match.PredAway"
                                   IsSelected="@match.IsSelected"
                                   IsLast="@(idx == Matches.Count - 1)"
                                   OnSelect="() => SelectMatch(match)" />
                }
            </MatchListPanel>

            @if (ActiveMatch is { } am)
            {
                <div class="bb-dcard calendar-detail-card">
                    <CalendarDetailHeader Phase="@am.Phase"
                                         Time="@am.Time"
                                         HomeCode="@am.HomeCode"
                                         AwayCode="@am.AwayCode"
                                         HomeName="@am.HomeName"
                                         AwayName="@am.AwayName" />
                    <div class="calendar-detail-body">
                        <PredictionInput HomePrediction="@PredHome"
                                         AwayPrediction="@PredAway"
                                         IsLocked="false"
                                         IsBusy="false"
                                         HomePredictionChanged="v => PredHome = v"
                                         AwayPredictionChanged="v => PredAway = v" />
                        <PoolSelector>
                            @foreach (var pool in PoolSelections)
                            {
                                <PoolSelectionItem Name="@pool.Name"
                                                   Sub="@pool.Sub"
                                                   Selected="@pool.Selected"
                                                   OnToggle="() => pool.Selected = !pool.Selected" />
                            }
                        </PoolSelector>
                        <CalendarDetailActions SelectedPoolCount="@PoolSelections.Count(p => p.Selected)"
                                               OnClear="ClearPrediction"
                                               OnSave="SavePrediction" />
                    </div>
                </div>
            }
            else
            {
                <div class="bb-dcard calendar-detail-empty">
                    <span class="calendar-detail-empty-label">Selecione um jogo para palpitar.</span>
                </div>
            }

        </div>

    </main>
</div>

@code {
    private string SelectedDay { get; set; } = "14";

    private record DayItem(string DayName, string DayNum, string Label, int MatchCount);
    private static readonly IReadOnlyList<DayItem> Days =
    [
        new("QUI", "13", "13", 4),
        new("SEX", "14", "14", 4),
        new("SÁB", "15", "15", 4),
        new("DOM", "16", "16", 4),
        new("SEG", "17", "17", 2),
        new("TER", "18", "18", 2),
        new("QUA", "19", "19", 2),
    ];

    private sealed class MatchItem
    {
        public string Time { get; init; } = "";
        public string HomeCode { get; init; } = "";
        public string AwayCode { get; init; } = "";
        public string HomeName { get; init; } = "";
        public string AwayName { get; init; } = "";
        public string Phase { get; init; } = "";
        public string Status { get; init; } = "open";
        public string? ClosesIn { get; init; }
        public string? Minute { get; init; }
        public int LiveHome { get; init; }
        public int LiveAway { get; init; }
        public int PredHome { get; init; }
        public int PredAway { get; init; }
        public bool IsSelected { get; set; }
    }

    private sealed class PoolSelection
    {
        public string Name { get; init; } = "";
        public string Sub { get; init; } = "";
        public bool Selected { get; set; }
    }

    private List<MatchItem> Matches { get; } =
    [
        new() { Time = "13:00", HomeCode = "FRA", HomeName = "França",     AwayCode = "SUI", AwayName = "Suíça",      Phase = "Grupo D", Status = "pred", PredHome = 2, PredAway = 1 },
        new() { Time = "16:00", HomeCode = "ARG", HomeName = "Argentina",  AwayCode = "MEX", AwayName = "México",     Phase = "Grupo A", Status = "open", ClosesIn = "1h 47m", IsSelected = true },
        new() { Time = "19:00", HomeCode = "BRA", HomeName = "Brasil",     AwayCode = "SUI", AwayName = "Suíça",      Phase = "Grupo G", Status = "live", Minute = "38'", LiveHome = 1, LiveAway = 0 },
        new() { Time = "22:00", HomeCode = "ENG", HomeName = "Inglaterra", AwayCode = "USA", AwayName = "EUA",        Phase = "Grupo B", Status = "open", ClosesIn = "7h 55m" },
    ];

    private List<PoolSelection> PoolSelections { get; } =
    [
        new() { Name = "Trampo TechCo",      Sub = "28 membros · você #1", Selected = true },
        new() { Name = "Família Silva 2026", Sub = "12 membros · você #2", Selected = true },
        new() { Name = "Galera do FC",       Sub = "8 membros · você #5",  Selected = false },
    ];

    private int PredHome { get; set; } = 2;
    private int PredAway { get; set; } = 1;

    private MatchItem? ActiveMatch => Matches.FirstOrDefault(m => m.IsSelected);

    private void SelectMatch(MatchItem match)
    {
        foreach (var m in Matches) m.IsSelected = false;
        match.IsSelected = true;
    }

    private void ClearPrediction()
    {
        PredHome = 0;
        PredAway = 0;
    }

    private void SavePrediction() { }
}

<style>
    .calendar-layout {
        flex: 1;
        padding: 0 40px 40px;
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 20px;
        min-height: 0;
        overflow: hidden;
    }

    .calendar-detail-card {
        padding: 0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .calendar-detail-body {
        padding: 20px 24px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
        overflow-y: auto;
    }

    .calendar-detail-empty {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .calendar-detail-empty-label {
        font-size: 13px;
        color: var(--fg-3);
    }
</style>
