@using BigBall.Web.Shared.State
@inject TeamBadgeCache TeamBadges
@inject IUserTimeZoneProvider Tz

<div class="featured-match-card">
    @if (Next is not null)
    {
        <div class="featured-match-card-header">
            <span class="bb-chip">Próximo jogo</span>
            <div class="featured-match-card-kickoff">
                <PredictionLockCountdownChip KickoffUtc="NextMatchKickoff" />
            </div>
        </div>

        <div class="featured-match-card-display">
            <div class="featured-match-team">
                <Flag Code="@((string)Next.HomeCode)" Size="88" ImageUrl="@TeamBadges.GetBadgeUrl((string)Next.HomeCode)" />
                <div class="featured-match-team-code">@Next.HomeCode</div>
            </div>
            <div class="featured-match-center">
                <div class="featured-match-datetime">@NextDateLine</div>
                <div class="featured-match-vs">vs</div>
                @{
                    var grpLabel = MatchLabels.GroupLabel((string?)Next.GroupLabel);
                }
                @if (!string.IsNullOrEmpty(grpLabel))
                {
                    <div class="featured-match-group">@grpLabel</div>
                }
            </div>
            <div class="featured-match-team">
                <Flag Code="@((string)Next.AwayCode)" Size="88" ImageUrl="@TeamBadges.GetBadgeUrl((string)Next.AwayCode)" />
                <div class="featured-match-team-code">@Next.AwayCode</div>
            </div>
        </div>

        <div class="featured-match-card-footer featured-match-pools">
            @foreach (dynamic pp in PoolPredictions ?? Array.Empty<object>())
            {
                <div class="featured-match-pool-row">
                    <span class="featured-match-pool-name">@pp.PoolName</span>
                    <div class="featured-match-pool-scores">
                        @if (pp.Prediction is { } pred)
                        {
                            <ScoreBox Value="@pred.Home" Size="sm" Editable />
                            <span class="featured-match-separator">×</span>
                            <ScoreBox Value="@pred.Away" Size="sm" Editable />
                        }
                        else
                        {
                            <span class="featured-match-separator">—</span>
                        }
                    </div>
                    <button class="bb-topbar-btn primary featured-match-pool-action"
                            @onclick="() => OnPredictionClick.InvokeAsync((Guid)pp.PoolId)">
                        @(IsLocked ? "Ver" : pp.Prediction is null ? "Palpitar" : "Alterar")
                    </button>
                </div>
            }
        </div>
    }
    else if (IsBusy)
    {
        <div class="featured-match-card-empty">
            <span class="featured-match-card-empty-text">Carregando…</span>
        </div>
    }
    else
    {
        <div class="featured-match-card-empty">
            <span class="featured-match-card-empty-text">Nenhum jogo em destaque no momento.</span>
        </div>
    }
</div>

@code {
    [Parameter] public dynamic? Next { get; set; }
    [Parameter] public System.Collections.IEnumerable? PoolPredictions { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public EventCallback<Guid> OnPredictionClick { get; set; }

    private DateTime NextMatchKickoff => Next is null ? default : (DateTime)Next.KickoffUtc;
    private bool IsLocked => Next is not null && (DateTime)Next.KickoffUtc <= DateTime.UtcNow;

    private string NextDateLine
    {
        get
        {
            if (Next is null) return "";
            var local = Tz.ToLocal((DateTime)Next.KickoffUtc);
            return $"{PtDates.AbbreviatedDay(local.DayOfWeek)} {local:dd} · {local:HH:mm} {Tz.OffsetLabel}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await TeamBadges.EnsureLoadedAsync();
    }
}

<style>
    .featured-match-card {
        padding: 0;
        overflow: hidden;
    }

    .featured-match-card-header {
        padding: 16px 24px;
        display: flex;
        align-items: center;
        border-bottom: 1px solid var(--line);
    }

    .featured-match-card-kickoff {
        margin-left: auto;
        font-size: 13px;
        color: var(--fg-2);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .kickoff-time {
        color: var(--fg);
        font-variant-numeric: tabular-nums;
    }

    .featured-match-card-display {
        padding: 32px 40px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 32px;
    }

    .featured-match-team {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
    }

    .featured-match-team-code {
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    .featured-match-center {
        text-align: center;
    }

    .featured-match-datetime {
        font-size: 11px;
        color: var(--fg-3);
        letter-spacing: 0.08em;
    }

    .featured-match-vs {
        font-family: var(--font-display);
        font-size: 64px;
        font-weight: 700;
        color: var(--fg-2);
        letter-spacing: -0.04em;
        line-height: 1;
        margin: 8px 0;
    }

    .featured-match-group {
        font-size: 12px;
        color: var(--fg-3);
    }

    .featured-match-card-footer {
        padding: 16px 24px;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: var(--bg-elev-2);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .featured-match-pools {
        display: grid;
        grid-template-columns: max-content max-content 1fr;
        align-items: center;
        gap: 10px 28px;
    }

    .featured-match-pool-row {
        display: contents;
    }

    .featured-match-pool-name {
        font-size: 13px;
        color: var(--fg-2);
        font-weight: 500;
    }

    .featured-match-pool-scores {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .featured-match-pool-action {
        justify-self: end;
    }

    .featured-match-separator {
        color: var(--fg-3);
    }

    .featured-match-card-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 200px;
    }

    .featured-match-card-empty-text {
        color: var(--fg-3);
    }

    /* ─── Mobile (≤768px): bandeiras/“vs” menores para não estourar o card ───
       Padding, gap e font-size do display são inline e venciam a media query
       de tokens-mobile.css. O tamanho da bandeira vem de um style inline no
       <img> (width = Size×1.5 = 132px), então só um !important o reduz.
       Desktop permanece inalterado. */
    @@media (max-width: 768px) {
        .featured-match-card-display {
            padding: 20px 16px;
            gap: 10px;
        }

        .featured-match-vs {
            font-size: 40px;
            margin: 4px 0;
        }

        .featured-match-team-code {
            font-size: 18px;
        }

        .featured-match-team {
            min-width: 0;
        }

        .featured-match-card-display .flag-img {
            width: 60px !important;
            height: 40px !important;
        }
    }
</style>
