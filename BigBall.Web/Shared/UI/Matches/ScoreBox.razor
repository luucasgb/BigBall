@* Tabular-numeric score cell. *@
<div style="@Style">@(Value?.ToString() ?? "—")</div>

@code {
    [Parameter] public int? Value { get; set; }
    [Parameter] public bool Editable { get; set; }
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public string Tone { get; set; } = "default";

    private string Style
    {
        get
        {
            int h = Size switch { "lg" => 64, "sm" => 32, _ => 44 };
            int fs = Size switch { "lg" => 32, "sm" => 17, _ => 24 };
            var border = Tone switch
            {
                "correct" => "var(--success)",
                "wrong" => "var(--danger)",
                _ => Editable ? "var(--line-strong)" : "var(--line)"
            };
            return string.Join(';',
                $"min-width:{h}px",
                $"height:{h}px",
                "padding:0 10px",
                "border-radius:10px",
                $"border:1.5px solid {border}",
                $"background:{(Editable ? "var(--bg-elev)" : "transparent")}",
                "display:flex",
                "align-items:center",
                "justify-content:center",
                "font-family:var(--font-display)",
                $"font-size:{fs}px",
                "font-weight:600",
                "font-variant-numeric:tabular-nums",
                "letter-spacing:-0.02em",
                "color:var(--fg)");
        }
    }
}
