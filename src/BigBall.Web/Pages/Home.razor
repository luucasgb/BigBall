@page "/"
@inject HomeViewModel VM
@inject BigBall.Client.Core.Abstractions.ITokenStore TokenStore
@inject NavigationManager Nav
@implements IDisposable

<div class="bb-desk theme-dark">
    <Sidebar Active="dashboard" />
    <main class="bb-main">
        <DesktopTopbar />
        <div class="bb-content">

            <div class="bb-page-h">
                <div style="flex:1;">
                    <div class="bb-page-eyebrow">BigBall · Copa do Mundo 2026</div>
                    <div class="bb-page-title">Início</div>
                    @if (VM.FeaturedNextMatch is { } fn)
                    {
                        <div class="bb-page-sub">@VM.Pools.Count bolão(ões) ativo(s) · próximo palpite fecha em @FormatKickoff(fn.KickoffUtc)</div>
                    }
                </div>
            </div>

            <div style="padding:0 40px 24px;display:grid;grid-template-columns:2fr 1fr;gap:20px;">

                @if (VM.FeaturedNextMatch is { } next && VM.FeaturedPool is { } featured)
                {
                    <div class="bb-dcard" style="padding:0;overflow:hidden;">
                        <div style="padding:16px 24px;display:flex;align-items:center;border-bottom:1px solid var(--line);">
                            <span class="bb-chip">Próximo · @featured.Name</span>
                            <div style="margin-left:auto;font-size:13px;color:var(--fg-2);display:flex;align-items:center;gap:6px;">
                                <Icon Path="@IconPaths.Lock" Size="14" /> Fecha em
                                <b style="color:var(--fg);font-variant-numeric:tabular-nums;">@FormatKickoff(next.KickoffUtc)</b>
                            </div>
                        </div>
                        <div style="padding:32px 40px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:32px;">
                            <div style="display:flex;flex-direction:column;align-items:center;gap:14px;">
                                <Flag Code="@next.HomeCode" Size="88" />
                                <div style="font-family:var(--font-display);font-size:22px;font-weight:600;letter-spacing:-0.02em;">@next.HomeCode</div>
                            </div>
                            <div style="text-align:center;">
                                <div style="font-size:11px;color:var(--fg-3);letter-spacing:0.08em;">@next.KickoffUtc.ToLocalTime().ToString("ddd dd · HH:mm") BRT</div>
                                <div style="font-family:var(--font-display);font-size:64px;font-weight:700;color:var(--fg-2);letter-spacing:-0.04em;line-height:1;margin:8px 0;">vs</div>
                                @if (next.GroupLabel is { } grp)
                                {
                                    <div style="font-size:12px;color:var(--fg-3);">@grp</div>
                                }
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:center;gap:14px;">
                                <Flag Code="@next.AwayCode" Size="88" />
                                <div style="font-family:var(--font-display);font-size:22px;font-weight:600;letter-spacing:-0.02em;">@next.AwayCode</div>
                            </div>
                        </div>
                        <div style="padding:16px 24px;border-top:1px solid var(--line);background:var(--bg-elev-2);display:flex;align-items:center;gap:12px;">
                            @if (next.MyPrediction is { } pred)
                            {
                                <div style="font-size:13px;color:var(--fg-2);">Seu palpite</div>
                                <ScoreBox Value="@pred.Home" Size="sm" Editable />
                                <span style="color:var(--fg-3);">×</span>
                                <ScoreBox Value="@pred.Away" Size="sm" Editable />
                            }
                            else
                            {
                                <div style="font-size:13px;color:var(--fg-2);">Você ainda não palpitou neste jogo.</div>
                            }
                            <div style="flex:1;"></div>
                            <button class="bb-topbar-btn primary"
                                    @onclick="() => VM.OpenFeaturedPredictionCommand.Execute(null)">
                                @(next.MyPrediction is null ? "Palpitar" : "Ver / editar")
                            </button>
                        </div>
                    </div>
                }
                else if (VM.IsBusy)
                {
                    <div class="bb-dcard" style="display:flex;align-items:center;justify-content:center;min-height:200px;">
                        <span style="color:var(--fg-3);">Carregando…</span>
                    </div>
                }
                else
                {
                    <div class="bb-dcard" style="display:flex;align-items:center;justify-content:center;min-height:200px;">
                        <span style="color:var(--fg-3);">Nenhum jogo em destaque no momento.</span>
                    </div>
                }

                <div style="display:flex;flex-direction:column;gap:20px;">
                    @if (VM.Pools.Count > 0)
                    {
                        var best = VM.Pools.OrderBy(p => p.MyRank).First();
                        <div class="bb-dcard">
                            <div style="font-size:11px;color:var(--fg-3);letter-spacing:0.08em;text-transform:uppercase;font-weight:600;">Sua melhor posição</div>
                            <div style="display:flex;align-items:baseline;gap:8px;margin-top:8px;">
                                <div style="font-family:var(--font-display);font-size:52px;font-weight:700;letter-spacing:-0.03em;color:var(--brand-strong);">#@best.MyRank</div>
                            </div>
                            <div style="font-size:13px;color:var(--fg-2);margin-top:4px;">@best.Name · @best.MyPoints pts</div>
                        </div>
                    }
                    <div class="bb-dcard">
                        <div class="bb-dcard-h">
                            <div class="bb-dcard-title">Resumo</div>
                        </div>
                        <div style="font-size:13px;color:var(--fg-2);">@VM.Pools.Count bolão(ões) ativo(s)</div>
                        @if (!string.IsNullOrEmpty(VM.ErrorMessage))
                        {
                            <div class="bb-error" style="margin-top:8px;">@VM.ErrorMessage</div>
                        }
                    </div>
                </div>
            </div>

            <div style="padding:0 40px 40px;display:grid;grid-template-columns:2fr 1fr;gap:20px;">
                <div class="bb-dcard">
                    <div class="bb-dcard-h">
                        <div class="bb-dcard-title">Meus bolões</div>
                    </div>
                    @if (VM.Pools.Count == 0 && !VM.IsBusy)
                    {
                        <div class="bb-empty">Você ainda não participa de nenhum bolão.</div>
                    }
                    else
                    {
                        <table class="bb-table">
                            <thead>
                                <tr>
                                    <th>Bolão</th>
                                    <th>Próximo jogo</th>
                                    <th>Líder</th>
                                    <th style="text-align:right;">Pos.</th>
                                    <th style="text-align:right;">Pts</th>
                                    <th style="text-align:right;">Membros</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pool in VM.Pools)
                                {
                                    <tr @onclick="() => OpenPool(pool)" style="cursor:pointer;">
                                        <td>
                                            <div style="display:flex;align-items:center;gap:12px;">
                                                <div style="width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;background:@PoolIconBg(pool.MyRank);color:@PoolIconColor(pool.MyRank);">
                                                    <Icon Path="@IconPaths.Trophy" Size="16" />
                                                </div>
                                                <div style="font-weight:500;">@pool.Name</div>
                                            </div>
                                        </td>
                                        <td style="color:var(--fg-2);font-size:13px;">
                                            @if (pool.NextMatch is { } nm)
                                            {
                                                @($"{nm.HomeCode} × {nm.AwayCode} · {FormatKickoff(nm.KickoffUtc)}")
                                            }
                                            else
                                            {
                                                <span>—</span>
                                            }
                                        </td>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:8px;">
                                                <Avatar Name="@pool.Leader.Name" Size="22" />
                                                <span style="font-size:13px;">@pool.Leader.Name</span>
                                                <span style="font-size:12px;color:var(--fg-3);font-variant-numeric:tabular-nums;">@pool.Leader.Points</span>
                                            </div>
                                        </td>
                                        <td class="num" style="color:@(pool.MyRank == 1 ? "var(--brand-strong)" : "var(--fg)");">#@pool.MyRank</td>
                                        <td class="num">@pool.MyPoints</td>
                                        <td class="num" style="color:var(--fg-2);">@pool.MemberCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="bb-dcard">
                    <div class="bb-dcard-h">
                        <div class="bb-dcard-title">Atividade</div>
                    </div>
                    <div style="font-size:13px;color:var(--fg-3);text-align:center;padding:24px 0;">
                        Feed de atividade em breve.
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        VM.PropertyChanged += OnVmChanged;
        ((System.Collections.Specialized.INotifyCollectionChanged)VM.Pools).CollectionChanged += OnPoolsChanged;

        var token = await TokenStore.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await VM.LoadCommand.ExecuteAsync(null);

        if (VM.ErrorMessage is not null && string.IsNullOrEmpty(await TokenStore.GetTokenAsync()))
            Nav.NavigateTo("/login", replace: true);
    }

    private void OnVmChanged(object? s, System.ComponentModel.PropertyChangedEventArgs e) => InvokeAsync(StateHasChanged);
    private void OnPoolsChanged(object? s, System.Collections.Specialized.NotifyCollectionChangedEventArgs e) => InvokeAsync(StateHasChanged);
    private void OpenPool(MyPoolDto pool) => VM.OpenPoolCommand.Execute(pool);

    private static string PoolIconBg(int rank) =>
        rank == 1 ? "color-mix(in oklab, var(--brand-strong) 20%, transparent)" : "var(--chip-bg)";
    private static string PoolIconColor(int rank) =>
        rank == 1 ? "var(--brand-strong)" : "var(--fg-2)";

    private static string FormatKickoff(DateTime utc)
    {
        var delta = utc - DateTime.UtcNow;
        if (delta <= TimeSpan.Zero) return "agora";
        if (delta.TotalHours < 24) return $"em {(int)delta.TotalHours}h {delta.Minutes:D2}m";
        return $"em {(int)delta.TotalDays}d";
    }

    public void Dispose()
    {
        VM.PropertyChanged -= OnVmChanged;
        ((System.Collections.Specialized.INotifyCollectionChanged)VM.Pools).CollectionChanged -= OnPoolsChanged;
    }
}
