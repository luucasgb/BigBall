@* Fixed left-nav sidebar shared across all desktop screens. *@
@using BigBall.Client.Core.Abstractions
@inject IAuthApi AuthApi
@inject ITokenStore TokenStore

<SidebarFrame>
    <div class="bb-logo">
        <div class="bb-logo-mark">
            <Icon Path="@IconPaths.Trophy" Size="20" />
        </div>
        <div class="bb-logo-text">BigBall</div>
    </div>

    <SidebarNavSection>Bolões</SidebarNavSection>
    <SidebarNavItem IconPath="@IconPaths.Home"
                    Label="Início"
                    Href="/"
                    IsActive="@(Active == "dashboard")" />
    <SidebarNavItem IconPath="@IconPaths.Calendar"
                    Label="Calendário"
                    Href="/calendar"
                    IsActive="@(Active == "calendar")" />
    <SidebarNavItem IconPath="@IconPaths.Whistle"
                    Label="Palpitar"
                    Href="/predict"
                    IsActive="@(Active == "predict")" />
    <SidebarNavItem IconPath="@IconPaths.Globe"
                    Label="Descobrir"
                    Title="Em breve" />

    <SidebarNavSection>Conta</SidebarNavSection>
    <SidebarNavItem IconPath="@IconPaths.User"
                    Label="Perfil"
                    Href="/profile"
                    IsActive="@(Active == "profile")" />

    <SidebarUserFooter Name="@ResolvedUserName" Email="@ResolvedUserEmail" AvatarUrl="@ResolvedAvatarUrl" />
</SidebarFrame>

@code {
    [Parameter] public string Active { get; set; } = string.Empty;
    [Parameter] public string UserName { get; set; } = string.Empty;
    [Parameter] public string UserEmail { get; set; } = string.Empty;

    private string ResolvedUserName { get; set; } = string.Empty;
    private string ResolvedUserEmail { get; set; } = string.Empty;
    private string? ResolvedAvatarUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ResolvedUserName = UserName;
        ResolvedUserEmail = UserEmail;

        var token = await TokenStore.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
        {
            return;
        }

        try
        {
            var profile = await AuthApi.GetMyProfileAsync();
            ResolvedUserName = string.IsNullOrWhiteSpace(profile.DisplayName) ? UserName : profile.DisplayName;
            ResolvedUserEmail = string.IsNullOrWhiteSpace(profile.Email) ? UserEmail : profile.Email;
            ResolvedAvatarUrl = string.IsNullOrWhiteSpace(profile.AvatarUrl) ? null : profile.AvatarUrl;
        }
        catch
        {
            // Keep provided fallback values when profile fetch fails.
        }
    }
}
