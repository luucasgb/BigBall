<!-- Card displaying current user's position and points -->
<div class="my-position-card">
    <div class="my-position-header">
        <div class="my-position-title">Minha posição</div>
    </div>
    <div class="my-position-stats">
        <div class="position-stat">
            <div class="stat-label">Posição</div>
            <div class="stat-value position-value">#@Position</div>
        </div>
        <div class="position-stat">
            <div class="stat-label">Pontos</div>
            <div class="stat-value">@Points</div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Position { get; set; }
    [Parameter] public int Points { get; set; }
}

<style>
    .my-position-card {
        background: var(--bg-elev);
        border: 1px solid var(--line);
        border-radius: 16px;
        overflow: hidden;
    }

    .my-position-header {
        padding: 16px 24px;
        border-bottom: 1px solid var(--line);
    }

    .my-position-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--fg);
    }

    .my-position-stats {
        padding: 24px 32px;
        display: flex;
        gap: 32px;
    }

    .position-stat {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .stat-label {
        font-size: 11px;
        color: var(--fg-3);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 600;
    }

    .stat-value {
        font-family: var(--font-display);
        font-size: 40px;
        font-weight: 700;
        letter-spacing: -0.02em;
        font-variant-numeric: tabular-nums;
    }

    .position-value {
        color: var(--brand-strong);
    }
</style>
