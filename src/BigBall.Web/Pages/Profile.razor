@page "/profile"
@using System.Globalization
@using BigBall.Client.Core.Abstractions
@using BigBall.Shared.Dtos
@inject IAuthSession AuthSession
@inject IAuthApi AuthApi
@inject IPoolsApi PoolsApi
@inject ITokenStore TokenStore
@inject NavigationManager Nav

<div class="bb-desk theme-dark">
    <Sidebar Active="profile" />
    <main class="bb-main">
        <DesktopTopbar Placeholder="Buscar membros, partidas, palpites…" />

        <PageHeader Title="Perfil" Eyebrow="Conta">
            <Actions>
                <button class="bb-topbar-btn"><Icon Path="@IconPaths.Share" Size="16" /> Compartilhar</button>
                <button class="bb-topbar-btn primary"><Icon Path="@IconPaths.Pen" Size="16" /> Editar</button>
            </Actions>
        </PageHeader>

        <div class="bb-content">
            @if (_isBusy)
            {
                <div class="profile-loading">Carregando perfil…</div>
            }
            else if (_error is not null)
            {
                <div class="profile-error">@_error</div>
            }
            else if (_profile is not null)
            {
            <ProfileHero
                Name="@_profile.DisplayName"
                AvatarUrl="@_profile.AvatarUrl"
                Handle="@GetHandleFromEmail(_profile.Email)"
                Email="@_profile.Email"
                MemberSince="@FormatMemberSince(_profile.CreateDate)"
                Timezone="America/São_Paulo (BRT)"
                AdminOfLabel="@_adminOfLabel"
                MemberLabel="@_memberLabel"
                KpiItems="@_kpiItems" />

            <div class="profile-layout">
                <div class="profile-column-left">
                    <ScoringBandsCard
                        Title="Pontos por faixa"
                        Subtitle="dados de exemplo (resumo global em breve)"
                        Items="@ScoringBandItems" />

                    <SubmissionsCard
                        Title="Palpites enviados"
                        Count="0"
                        Total="0"
                        FooterLeft="Estatística global em breve"
                        FooterRight="—" />
                </div>

                <div class="profile-column-center">
                    <ActivityTable
                        Title="Atividade de palpites"
                        ViewAllLabel="Ver tudo"
                        Items="@ActivityItems" />

                    <MyPoolsCard
                        Title="Meus bolões"
                        ViewAllLabel="Ver todos"
                        Items="@_poolItems" />
                </div>

                <div class="profile-column-right">
                    <AccountSettingsCard
                        Title="Conta"
                        Items="@_accountSettingsItems" />

                    <button type="button"
                            class="bb-btn bb-btn-ghost logout-btn"
                            disabled="@_loggingOut"
                            @onclick="LogoutAsync">
                        Sair da conta
                    </button>
                </div>
            </div>
            }
        </div>
    </main>
</div>

@code {
    private bool _isBusy = true;
    private string? _error;
    private ProfileDto? _profile;
    private IReadOnlyList<ProfileKpis.KpiItem> _kpiItems = [];
    private IReadOnlyList<MyPoolsCard.PoolItem> _poolItems = [];
    private IReadOnlyList<AccountSettingsCard.SettingRow> _accountSettingsItems = [];
    private string? _adminOfLabel;
    private string _memberLabel = string.Empty;
    private bool _loggingOut;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(await TokenStore.GetTokenAsync()))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        try
        {
            var profileTask = AuthApi.GetMyProfileAsync();
            var poolsTask = PoolsApi.GetMyPoolsAsync();
            await Task.WhenAll(profileTask, poolsTask);

            _profile = await profileTask;
            var pools = await poolsTask;

            _adminOfLabel = null; /* Membro de bolão exige detalhe por bolão; acrescentar quando a API expuser o papel. */
            _memberLabel = pools.Count == 0
                ? "Membro · 0 bolões"
                : $"Membro · {pools.Count} bolão(ões)";

            _kpiItems = BuildKpiItems(pools);
            _poolItems = pools
                .Select(p => new MyPoolsCard.PoolItem(p.Name, p.MemberCount, false, p.MyRank, p.MyPoints))
                .ToList();
            _accountSettingsItems = BuildAccountSettings(_profile);
        }
        catch (Exception ex)
        {
            _error = $"Não foi possível carregar o perfil. {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static IReadOnlyList<AccountSettingsCard.SettingRow> BuildAccountSettings(ProfileDto p) =>
    [
        new(IconPaths.User, "Nome de exibição", p.DisplayName),
        new(IconPaths.Bell, "Notificações", "Lock T-5min · resultados"),
        new(IconPaths.Globe, "Fuso horário", "America/São_Paulo (BRT)"),
        new(IconPaths.Lock, "Privacidade & dados", "LGPD · exportar · excluir")
    ];

    private static IReadOnlyList<ProfileKpis.KpiItem> BuildKpiItems(IReadOnlyList<MyPoolDto> pools)
    {
        if (pools.Count == 0)
        {
            return
            [
                new("Pontos totais", "0", "nenhum bolão ainda", IsHighlight: true),
                new("Melhor posição", "—", "—"),
                new("Placar exato", "—", "em breve"),
                new("Bônus pênaltis", "—", "em breve")
            ];
        }

        var totalPoints = pools.Sum(p => p.MyPoints);
        var best = pools.Min(p => p.MyRank);
        return
        [
            new("Pontos totais", totalPoints.ToString(CultureInfo.InvariantCulture), $"em {pools.Count} bolão(ões)", IsHighlight: true),
            new("Melhor posição", $"#{best}", "menor # entre teus bolões"),
            new("Placar exato", "—", "em breve"),
            new("Bônus pênaltis", "—", "em breve")
        ];
    }

    private static string GetHandleFromEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            return string.Empty;
        }

        var at = email.IndexOf('@');
        var local = at > 0 ? email[..at] : email;
        return "@" + local;
    }

    private static string FormatMemberSince(DateTime utc) =>
        $"Membro desde {utc.ToString("MMM/yyyy", CultureInfo.GetCultureInfo("pt-BR"))}";

    private async Task LogoutAsync()
    {
        if (_loggingOut) return;
        _loggingOut = true;
        try
        {
            await AuthSession.LogoutAsync();
        }
        finally
        {
            _loggingOut = false;
        }
    }

    private static readonly IReadOnlyList<ScoringBandsCard.BandItem> ScoringBandItems =
    [
        new(20, "Placar exato", 0),
        new(16, "Vencedor + saldo", 0),
        new(15, "Vencedor + 1 placar", 0),
        new(10, "Apenas vencedor", 0),
        new(5,  "Apenas 1 placar", 0),
        new(0,  "Sem pontos", 0)
    ];

    private static readonly IReadOnlyList<ActivityTable.ActivityRow> ActivityItems =
    [
        new("—",  "—",  "—", "—", 0, "Dados de exemplo")
    ];
}

<style>
    .profile-layout {
        padding: 0 40px 40px;
        display: grid;
        grid-template-columns: 1.05fr 1.4fr 1fr;
        gap: 20px;
    }

    .profile-column-left,
    .profile-column-center,
    .profile-column-right {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .logout-btn {
        width: 100%;
        height: 44px;
        color: var(--danger);
        border-color: color-mix(in oklab, var(--danger) 35%, var(--line));
    }

    .profile-loading,
    .profile-error {
        padding: 24px 40px;
        color: var(--fg-2);
    }

    .profile-error {
        color: var(--danger);
    }
</style>
