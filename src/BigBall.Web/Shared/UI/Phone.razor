@* The 360×760 phone frame that every screen renders inside. *@
<div class="bb-stage">
    <div class="bb-phone theme-@Theme">
        <StatusBar />
        @ChildContent
        <div class="bb-homebar"></div>
    </div>
</div>

@code {
    [Parameter] public string Theme { get; set; } = "dark";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
