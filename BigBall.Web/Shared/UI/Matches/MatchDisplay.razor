@using BigBall.Web.Shared.State
@inject TeamBadgeCache TeamBadges

<div class="match-display">
    <div class="match-display-inner">
        <div class="team-column">
            <Flag Code="@HomeCode" Size="72" ImageUrl="@TeamBadges.GetBadgeUrl(HomeCode)" />
            <div class="team-code">@HomeCode</div>
        </div>
        <div class="vs-divider">
            <div class="vs-text">vs</div>
        </div>
        <div class="team-column">
            <Flag Code="@AwayCode" Size="72" ImageUrl="@TeamBadges.GetBadgeUrl(AwayCode)" />
            <div class="team-code">@AwayCode</div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string HomeCode { get; set; } = "";
    [Parameter] public string AwayCode { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        await TeamBadges.EnsureLoadedAsync();
    }
}

<style>
    .match-display {
        padding: 32px 40px;
        overflow: hidden;
    }

    .match-display-inner {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 32px;
    }

    .team-column {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
    }

    .team-code {
        font-family: var(--font-display);
        font-size: 20px;
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    .vs-divider {
        text-align: center;
    }

    .vs-text {
        font-family: var(--font-display);
        font-size: 48px;
        font-weight: 700;
        color: var(--fg-2);
        letter-spacing: -0.04em;
        line-height: 1;
    }
</style>
