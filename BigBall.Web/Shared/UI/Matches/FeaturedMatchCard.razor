@using BigBall.Web.Shared.State
@inject TeamBadgeCache TeamBadges

<div class="featured-match-card">
    @if (Next is not null && Featured is not null)
    {
        <div class="featured-match-card-header">
            <span class="bb-chip">Próximo · @Featured.Name</span>
            <div class="featured-match-card-kickoff">
                <PredictionLockCountdownChip KickoffUtc="NextMatchKickoff" />
            </div>
        </div>

        <div class="featured-match-card-display">
            <div class="featured-match-team">
                <Flag Code="@((string)Next.HomeCode)" Size="88" ImageUrl="@TeamBadges.GetBadgeUrl((string)Next.HomeCode)" />
                <div class="featured-match-team-code">@Next.HomeCode</div>
            </div>
            <div class="featured-match-center">
                <div class="featured-match-datetime">@Next.KickoffUtc.ToLocalTime().ToString("ddd dd · HH:mm") BRT</div>
                <div class="featured-match-vs">vs</div>
                @if (Next.GroupLabel is { } grp)
                {
                    <div class="featured-match-group">@grp</div>
                }
            </div>
            <div class="featured-match-team">
                <Flag Code="@((string)Next.AwayCode)" Size="88" ImageUrl="@TeamBadges.GetBadgeUrl((string)Next.AwayCode)" />
                <div class="featured-match-team-code">@Next.AwayCode</div>
            </div>
        </div>

        <div class="featured-match-card-footer">
            @if (Next.MyPrediction is { } pred)
            {
                <div class="featured-match-prediction-label">Seu palpite</div>
                <ScoreBox Value="@pred.Home" Size="sm" Editable />
                <span class="featured-match-separator">×</span>
                <ScoreBox Value="@pred.Away" Size="sm" Editable />
            }
            else
            {
                <div class="featured-match-prediction-label">Você ainda não palpitou neste jogo.</div>
            }
            <div class="featured-match-footer-spacer"></div>
            <button class="bb-topbar-btn primary"
                    @onclick="() => OnPredictionClick.InvokeAsync(null)">
                @(Next.MyPrediction is null ? "Palpitar" : "Ver / editar")
            </button>
        </div>
    }
    else if (IsBusy)
    {
        <div class="featured-match-card-empty">
            <span class="featured-match-card-empty-text">Carregando…</span>
        </div>
    }
    else
    {
        <div class="featured-match-card-empty">
            <span class="featured-match-card-empty-text">Nenhum jogo em destaque no momento.</span>
        </div>
    }
</div>

@code {
    [Parameter] public dynamic? Next { get; set; }
    [Parameter] public dynamic? Featured { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public EventCallback OnPredictionClick { get; set; }

    private DateTime NextMatchKickoff => Next is null ? default : (DateTime)Next.KickoffUtc;

    protected override async Task OnInitializedAsync()
    {
        await TeamBadges.EnsureLoadedAsync();
    }
}

<style>
    .featured-match-card {
        padding: 0;
        overflow: hidden;
    }

    .featured-match-card-header {
        padding: 16px 24px;
        display: flex;
        align-items: center;
        border-bottom: 1px solid var(--line);
    }

    .featured-match-card-kickoff {
        margin-left: auto;
        font-size: 13px;
        color: var(--fg-2);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .kickoff-time {
        color: var(--fg);
        font-variant-numeric: tabular-nums;
    }

    .featured-match-card-display {
        padding: 32px 40px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 32px;
    }

    .featured-match-team {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
    }

    .featured-match-team-code {
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    .featured-match-center {
        text-align: center;
    }

    .featured-match-datetime {
        font-size: 11px;
        color: var(--fg-3);
        letter-spacing: 0.08em;
    }

    .featured-match-vs {
        font-family: var(--font-display);
        font-size: 64px;
        font-weight: 700;
        color: var(--fg-2);
        letter-spacing: -0.04em;
        line-height: 1;
        margin: 8px 0;
    }

    .featured-match-group {
        font-size: 12px;
        color: var(--fg-3);
    }

    .featured-match-card-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--line);
        background: var(--bg-elev-2);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .featured-match-prediction-label {
        font-size: 13px;
        color: var(--fg-2);
    }

    .featured-match-separator {
        color: var(--fg-3);
    }

    .featured-match-footer-spacer {
        flex: 1;
    }

    .featured-match-card-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 200px;
    }

    .featured-match-card-empty-text {
        color: var(--fg-3);
    }
</style>
