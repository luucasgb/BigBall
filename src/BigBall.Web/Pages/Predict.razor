@page "/pools/{PoolId:guid}/predict/{MatchId:guid}"
@page "/predict"
@layout DesktopAppLayout
@using BigBall.Client.Core.Abstractions
@inject PredictViewModel VM
@inject IPoolsApi PoolsApi
@inject NavigationManager Nav
@implements IDisposable

<DesktopTopbar />
<div class="bb-content">
    @if (VM.Match is { } m)
    {
        <MatchHeader Phase="@(m.GroupLabel ?? m.Phase)"
                     HomeCode="@m.HomeCode"
                     AwayCode="@m.AwayCode"
                     KickoffUtc="@m.KickoffUtc" />
    }
    else
    {
        <div class="bb-page-h">
            <div class="bb-page-title">Palpite</div>
        </div>
    }
    @{
        var headErr = _resolveError ?? VM.ErrorMessage;
    }
    @if (headErr is { } he)
    {
        <div style="padding:0 40px 24px;max-width:640px;">
            <ErrorAlert Message="@he" />
        </div>
    }

    @if (VM.Match is { } match)
    {
        <div class="prediction-page-grid">
            <MatchCard HomeCode="@match.HomeCode"
                       AwayCode="@match.AwayCode"
                       HomePrediction="@VM.HomePrediction"
                       AwayPrediction="@VM.AwayPrediction"
                       IsLocked="@VM.IsLocked"
                       IsBusy="@VM.IsBusy"
                       HomeReferenceScore="@match.ReferenceHome"
                       AwayReferenceScore="@match.ReferenceAway"
                       Preview="@VM.Preview"
                       HomePredictionChanged="v => VM.HomePrediction = v"
                       AwayPredictionChanged="v => VM.AwayPrediction = v" />

            <PredictionLayout>
                <ScoringRulesCard />
                <ErrorAlert Message="@VM.ErrorMessage" />
                <SavePredictionButton IsSaved="@VM.IsSaved"
                                      IsBusy="@VM.IsBusy"
                                      CanSave="@(VM.SaveCommand.CanExecute(null))"
                                      OnSave="() => VM.SaveCommand.ExecuteAsync(null)" />
            </PredictionLayout>
        </div>
    }
    else if (VM.IsBusy || _resolving)
    {
        <div style="padding:40px;color:var(--fg-3);">Carregando…</div>
    }
</div>

@code {
    [Parameter] public Guid PoolId { get; set; }
    [Parameter] public Guid MatchId { get; set; }

    private bool _resolving;
    private string? _resolveError;

    protected override async Task OnParametersSetAsync()
    {
        if (PoolId == Guid.Empty || MatchId == Guid.Empty)
        {
            _resolving = true;
            _resolveError = null;
            try
            {
                var pools = await PoolsApi.GetMyPoolsAsync();
                var featured = pools
                    .Where(p => p.NextMatch is not null)
                    .OrderBy(p => p.NextMatch!.KickoffUtc)
                    .FirstOrDefault()
                    ?? pools.FirstOrDefault();
                if (featured is null)
                {
                    _resolveError = "Nenhum bolão encontrado.";
                    return;
                }
                if (featured.NextMatch is null)
                {
                    _resolveError = "Não há partida aberta para palpite no momento.";
                    return;
                }
                Nav.NavigateTo($"/pools/{featured.Id}/predict/{featured.NextMatch.Id}", replace: true);
            }
            catch (Exception ex) when (ex is not OperationCanceledException)
            {
                _resolveError = ex.Message;
            }
            finally
            {
                _resolving = false;
            }
            return;
        }

        _resolveError = null;
        if (VM.PoolId == PoolId && VM.MatchId == MatchId) return;
        VM.PropertyChanged -= OnVmChanged;
        VM.PropertyChanged += OnVmChanged;
        VM.PoolId = PoolId;
        VM.MatchId = MatchId;
        await VM.LoadCommand.ExecuteAsync(null);
    }

    private void OnVmChanged(object? s, System.ComponentModel.PropertyChangedEventArgs e) => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        VM.PropertyChanged -= OnVmChanged;
        VM.Dispose();
    }
}

<style>
    .prediction-page-grid {
        padding: 0 40px 40px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        max-width: 960px;
    }
</style>
