<div class="match-list-item @(IsSelected ? "selected" : "") @(IsLast ? "last" : "")"
     @onclick="() => OnSelect.InvokeAsync()">
    <div class="match-list-item-time">
        @Time
        <div class="match-list-item-phase">@Phase</div>
        @if (!string.IsNullOrEmpty(VenueLine))
        {
            <div class="match-list-item-venue" title="@VenueLine">@VenueLine</div>
        }
    </div>
    <div class="match-list-item-teams">
        <div class="match-list-item-team">
            <Flag Code="@HomeCode" Size="24" />
            <div class="match-list-item-team-name">@HomeName</div>
            @if (Status == "live") { <span class="match-list-item-score">@LiveHome</span> }
            @if (Status == "pred") { <span class="match-list-item-pred">@PredHome</span> }
        </div>
        <div class="match-list-item-team">
            <Flag Code="@AwayCode" Size="24" />
            <div class="match-list-item-team-name">@AwayName</div>
            @if (Status == "live") { <span class="match-list-item-score">@LiveAway</span> }
            @if (Status == "pred") { <span class="match-list-item-pred">@PredAway</span> }
        </div>
    </div>
    <div class="match-list-item-status">
        @if (Status == "live") { <span class="bb-chip live">Ao vivo @Minute</span> }
        @if (Status == "pred") { <span class="bb-chip gold">Palpite salvo</span> }
        @if (Status == "open") { <PredictionLockCountdownChip KickoffUtc="@KickoffUtc" /> }
    </div>
</div>

@code {
    [Parameter] public string Time { get; set; } = "";
    [Parameter] public string Phase { get; set; } = "";
    [Parameter] public string HomeCode { get; set; } = "";
    [Parameter] public string AwayCode { get; set; } = "";
    [Parameter] public string HomeName { get; set; } = "";
    [Parameter] public string AwayName { get; set; } = "";
    [Parameter] public string? VenueLine { get; set; }
    [Parameter] public DateTime KickoffUtc { get; set; }
    [Parameter] public string Status { get; set; } = "open";
    [Parameter] public string? Minute { get; set; }
    [Parameter] public int LiveHome { get; set; }
    [Parameter] public int LiveAway { get; set; }
    [Parameter] public int PredHome { get; set; }
    [Parameter] public int PredAway { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsLast { get; set; }
    [Parameter] public EventCallback OnSelect { get; set; }
}

<style>
    .match-list-item {
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        border-bottom: 1px solid var(--line);
        border-left: 3px solid transparent;
        background: transparent;
        cursor: pointer;
        transition: background 0.1s;
    }

    .match-list-item.last {
        border-bottom: none;
    }

    .match-list-item.selected {
        background: color-mix(in oklab, var(--brand-strong) 8%, transparent);
        border-left-color: var(--brand-strong);
    }

    .match-list-item-time {
        width: 58px;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 16px;
        font-variant-numeric: tabular-nums;
        flex-shrink: 0;
    }

    .match-list-item-phase {
        font-size: 10px;
        font-family: var(--font-sans);
        font-weight: 500;
        color: var(--fg-3);
        letter-spacing: 0.04em;
        margin-top: 2px;
    }

    .match-list-item-venue {
        font-size: 9px;
        font-family: var(--font-sans);
        color: var(--fg-3);
        line-height: 1.25;
        margin-top: 4px;
        max-width: 72px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .match-list-item-teams {
        flex: 1;
        min-width: 0;
    }

    .match-list-item-team {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .match-list-item-team + .match-list-item-team {
        margin-top: 6px;
    }

    .match-list-item-team-name {
        font-size: 14px;
        font-weight: 500;
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .match-list-item-score {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 17px;
        font-variant-numeric: tabular-nums;
    }

    .match-list-item-pred {
        color: var(--fg-3);
        font-variant-numeric: tabular-nums;
        font-size: 13px;
    }

    .match-list-item-status {
        min-width: 128px;
        text-align: right;
        flex-shrink: 0;
    }
</style>
