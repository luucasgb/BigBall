@* Uppercase section label in the app sidebar (e.g. "Bolões", "Conta"). *@

<div class="nav-section">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
}

<style>
    .nav-section {
        font-size: 10px;
        color: var(--fg-3);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 16px 10px 8px;
        font-weight: 600;
    }
</style>
