@page "/pools/{PoolId:guid}"
@inject PoolDetailViewModel VM
@implements IDisposable

<Phone>
    <div class="bb-header">
        <div class="bb-iconbtn" @onclick="() => VM.GoBackCommand.Execute(null)"><Icon Path="@IconPaths.ChevronL" /></div>
        <div class="bb-header-title">@(VM.Pool?.Name ?? "Carregando…")</div>
        <div class="bb-iconbtn"><Icon Path="@IconPaths.Dots" /></div>
    </div>

    <div class="bb-scroll" style="display:flex;flex-direction:column;gap:14px;">
        @if (VM.Pool is { } pool)
        {
            <div class="bb-card" style="display:flex;flex-direction:column;gap:8px;">
                <div class="bb-row spread">
                    <div>
                        <div style="font-size:11px;color:var(--fg-3);letter-spacing:0.04em;text-transform:uppercase;">Minha posição</div>
                        <div class="bb-big-num">#@pool.MyPosition</div>
                    </div>
                    <div style="text-align:right;">
                        <div style="font-size:11px;color:var(--fg-3);letter-spacing:0.04em;text-transform:uppercase;">Pontos</div>
                        <div class="bb-big-num">@pool.MyPoints</div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(pool.PrizeDescription))
                {
                    <div style="font-size:12px;color:var(--fg-2);">Prêmio: <strong style="color:var(--fg);">@pool.PrizeDescription</strong></div>
                }
            </div>

            <SegmentedTabs T="PoolTab"
                           Items="@TabItems"
                           Selected="@VM.SelectedTab"
                           SelectedChanged="OnTabChanged" />

            @if (VM.SelectedTab == PoolTab.Ranking)
            {
                @if (VM.HasTieWithMe)
                {
                    <div class="bb-alert">
                        <Icon Path="@IconPaths.Alert" Size="18" />
                        <div>
                            <strong>Empate no ranking.</strong><br />
                            Critérios alfabético + sorteio ainda não aplicados neste stub (PRD 4.8).
                        </div>
                    </div>
                }

                <div class="bb-card" style="padding:6px 14px;">
                    @foreach (var row in VM.Ranking)
                    {
                        <div class="bb-rank-row @(row.IsMe ? "me" : "")">
                            <div class="bb-rank-pos">@row.Rank</div>
                            <Avatar Name="@row.Name" Size="28" />
                            <div>
                                <div class="bb-rank-name">@row.Name@(row.IsMe ? " (você)" : "")</div>
                                <div style="font-size:11px;color:var(--fg-3);">
                                    @row.Tier20Count × 20pts · @row.Tier16Count × 16pts
                                </div>
                            </div>
                            <div class="bb-rank-pts">@row.Points</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="bb-empty">Em breve.</div>
            }
        }
        else if (!string.IsNullOrEmpty(VM.ErrorMessage))
        {
            <div class="bb-error">@VM.ErrorMessage</div>
        }
    </div>

    <BottomNav Active="home" />
</Phone>

@code {
    [Parameter] public Guid PoolId { get; set; }

    private static readonly IReadOnlyList<SegmentedTabs<PoolTab>.Item> TabItems = new[]
    {
        new SegmentedTabs<PoolTab>.Item(PoolTab.Ranking, "Ranking"),
        new SegmentedTabs<PoolTab>.Item(PoolTab.Matches, "Jogos"),
        new SegmentedTabs<PoolTab>.Item(PoolTab.Prize,   "Prêmio"),
        new SegmentedTabs<PoolTab>.Item(PoolTab.Members, "Membros"),
    };

    protected override async Task OnParametersSetAsync()
    {
        if (VM.PoolId == PoolId) return;
        VM.PropertyChanged += OnVmChanged;
        ((System.Collections.Specialized.INotifyCollectionChanged)VM.Ranking).CollectionChanged += OnRankingChanged;
        VM.PoolId = PoolId;
        await VM.LoadCommand.ExecuteAsync(null);
    }

    private void OnVmChanged(object? s, System.ComponentModel.PropertyChangedEventArgs e) => InvokeAsync(StateHasChanged);
    private void OnRankingChanged(object? s, System.Collections.Specialized.NotifyCollectionChangedEventArgs e) => InvokeAsync(StateHasChanged);
    private void OnTabChanged(PoolTab tab) => VM.SelectedTab = tab;

    public void Dispose()
    {
        VM.PropertyChanged -= OnVmChanged;
        ((System.Collections.Specialized.INotifyCollectionChanged)VM.Ranking).CollectionChanged -= OnRankingChanged;
    }
}
