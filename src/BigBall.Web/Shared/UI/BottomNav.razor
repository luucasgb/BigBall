@inject Microsoft.AspNetCore.Components.NavigationManager Nav

<div class="bb-bottomnav">
    @foreach (var tab in Tabs)
    {
        <div class="bb-tab @(tab.Id == Active ? "active" : "") @(tab.Route is null ? "disabled" : "")"
             @onclick="() => OnTabClick(tab)">
            <Icon Path="@tab.Path" Size="22" />
            <span>@tab.Label</span>
        </div>
    }
</div>

@code {
    [Parameter] public string Active { get; set; } = "home";

    private record Tab(string Id, string Label, string Path, string? Route);

    private static readonly Tab[] Tabs =
    {
        new("home",      "Bolões",     IconPaths.Trophy,   "/"),
        new("calendar",  "Calendário", IconPaths.Calendar, null),
        new("discover",  "Descobrir",  IconPaths.Globe,    null),
        new("profile",   "Perfil",     IconPaths.User,     null),
    };

    private void OnTabClick(Tab tab)
    {
        if (tab.Route is null || tab.Id == Active) return;
        Nav.NavigateTo(tab.Route);
    }
}
