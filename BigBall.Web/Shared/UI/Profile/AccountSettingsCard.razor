@* Card showing account settings rows *@
<div class="account-settings-container">
    <div class="account-settings-title">
        <div class="bb-dcard-title">@Title</div>
    </div>
    @foreach (var (row, idx) in Items.Select((r, i) => (r, i)))
    {
        <div class="account-settings-row @(idx < Items.Count - 1 ? "account-settings-row-border" : "") @(row.OnClick.HasDelegate ? "account-settings-row-clickable" : "")"
             @onclick="row.OnClick">
            <div class="account-settings-icon">
                <Icon Path="@row.Icon" Size="18" />
            </div>
            <div class="account-settings-info">
                <div class="account-settings-label">@row.Label</div>
                <div class="account-settings-value">@row.Value</div>
            </div>
            @if (row.OnClick.HasDelegate)
            {
                <span class="account-settings-chevron">
                    <Icon Path="@IconPaths.Chevron" Size="16" />
                </span>
            }
        </div>
    }
</div>

@code {
    public record SettingRow(string Icon, string Label, string Value, EventCallback OnClick = default);

    [Parameter] public string Title { get; set; } = "Conta";
    [Parameter] public IReadOnlyList<SettingRow> Items { get; set; } = [];
}

<style>
    .account-settings-container {
        padding: 0;
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: 12px;
    }

    .account-settings-title {
        padding: 18px 20px;
        border-bottom: 1px solid var(--line);
    }

    .account-settings-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
    }

    .account-settings-row-clickable {
        cursor: pointer;
    }

    .account-settings-row-clickable:hover {
        background: var(--chip-bg);
    }

    .account-settings-row-border {
        border-bottom: 1px solid var(--line);
    }

    .account-settings-icon {
        color: var(--fg-2);
        flex-shrink: 0;
    }

    .account-settings-info {
        flex: 1;
        min-width: 0;
    }

    .account-settings-label {
        font-size: 13px;
        font-weight: 500;
    }

    .account-settings-value {
        font-size: 11px;
        color: var(--fg-3);
        margin-top: 2px;
    }

    .account-settings-chevron {
        color: var(--fg-3);
        flex-shrink: 0;
    }
</style>
