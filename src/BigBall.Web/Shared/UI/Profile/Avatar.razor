@* Initials circle with optional image (e.g. OAuth avatar), deterministic hue for fallback. *@

@if (_showImage)
{
    <div class="bb-avatar bb-avatar--img" style="@WrapStyle">
        <img class="bb-avatar__img"
             src="@ImageUrl"
             alt=""
             width="@Size"
             height="@Size"
             loading="lazy"
             referrerpolicy="no-referrer"
             @onerror="OnImageError" />
    </div>
}
else
{
    <div class="bb-avatar bb-avatar--initials" style="@WrapStyle;@InitStyle">@Initials</div>
}

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = string.Empty;
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public int Size { get; set; } = 28;
    [Parameter] public string? Color { get; set; }

    private string? _lastImageUrl;
    private bool _imageError;

    private bool _showImage =>
        !string.IsNullOrWhiteSpace(ImageUrl)
        && !_imageError;

    protected override void OnParametersSet()
    {
        if (ImageUrl != _lastImageUrl)
        {
            _lastImageUrl = ImageUrl;
            _imageError = false;
        }
    }

    private void OnImageError() => _imageError = true;

    private string Initials
    {
        get
        {
            var parts = (Name ?? string.Empty).Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 0)
            {
                return "?";
            }

            return string.Concat(parts.Take(2).Select(p => char.ToUpperInvariant(p[0])));
        }
    }

    private string InitStyle
    {
        get
        {
            var hue = 0;
            foreach (var c in Name) hue = (hue * 31 + c) % 360;
            var bg = Color ?? $"oklch(0.55 0.08 {hue})";
            var fontSize = (Size * 0.38).ToString("F0");
            return string.Join(';',
                $"background:{bg}",
                "color:#fff",
                "display:flex",
                "align-items:center",
                "justify-content:center",
                $"font-size:{fontSize}px",
                "font-weight:600",
                "letter-spacing:-0.02em",
                "flex-shrink:0");
        }
    }

    private string WrapStyle =>
        string.Join(';',
            $"width:{Size}px",
            $"height:{Size}px",
            "min-width:0",
            "border-radius:50%",
            "overflow:hidden",
            "flex-shrink:0");
}

<style>
    .bb-avatar--img,
    .bb-avatar--initials {
        box-sizing: border-box;
    }

    .bb-avatar--img {
        padding: 0;
        line-height: 0;
        background: var(--chip-bg);
    }

    .bb-avatar__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
</style>
